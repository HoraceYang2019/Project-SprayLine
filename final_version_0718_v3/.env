# SprayLine Final Version — Environment Variables
# Copy this file to .env and fill in your values.

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=sprayline

# ── API service (same vars, consumed by api_server.py / time_series_service.py) ─
SPRAYLINE_DB_HOST=db
SPRAYLINE_DB_PORT=5432
SPRAYLINE_DB_USER=postgres
SPRAYLINE_DB_PASSWORD=postgres
SPRAYLINE_DB_NAME=sprayline

# ── versionB DB module path (resolved automatically in Docker; set for local dev) ─
# VERSIONB_PATH=/path/to/final_version/database

# Apps Script Web App URL used only by the FastAPI engineer-task service.
ENGINEER_TASK_APP_SCRIPT_URL=https://script.google.com/macros/s/AKfycbyvPzX3epFpOH9AUFLLlD_-W4EXCOULHInUZKfmnCyJHlrCOY_HYTNSCBLtm3ZVzoWnBQ/exec

# LAN URL embedded in engineer email. Do not use localhost or 127.0.0.1.
ENGINEER_TASK_BASE_URL=http://192.168.0.113:8012

# Persistent attachment volume path inside the API container.
ENGINEER_TASK_ATTACHMENT_ROOT=/data/engineer-task-attachments
