# SprayLine Final Version — Environment Variables
# Copy this file to .env and fill in your values.

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=sprayline

# ── API service (same vars, consumed by api_server.py / time_series_service.py) ─
SPRAYLINE_DB_HOST=db
SPRAYLINE_DB_PORT=5432
SPRAYLINE_DB_USER=postgres
SPRAYLINE_DB_PASSWORD=postgres
SPRAYLINE_DB_NAME=sprayline

# ── versionB DB module path (resolved automatically in Docker; set for local dev) ─
# VERSIONB_PATH=/path/to/final_version/database
