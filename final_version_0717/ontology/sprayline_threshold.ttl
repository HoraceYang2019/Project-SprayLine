@prefix sl: <http://example.org/sprayline#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .


sl:SprayLineThresholdSet a sl:ThresholdSet ;
    sl:sourceFile "ontology/runtime_threshold_reference.csv" ;
    sl:version "0628_runtime" .

sl:Threshold_air_pressure_bar a sl:SensorThreshold ;
    sl:metricName "air_pressure_bar" ;
    sl:component "air_compressor" ;
    sl:componentZh "空壓系統" ;
    sl:unit "bar" ;
    sl:causeId "AIR_PRESSURE_UNSTABLE" ;
    sl:responseIds "CALIBRATE_PRESSURE_VALVE" ;
    sl:description "空壓壓力過低或過高會造成霧化不穩與噴塗不均" ;
    sl:belongsTo sl:SprayLineThresholdSet ;
    sl:normal_min "2.7"^^xsd:decimal ;
    sl:normal_max "3.8"^^xsd:decimal ;
    sl:warning_low_min "2.5"^^xsd:decimal ;
    sl:warning_low_max "2.7"^^xsd:decimal ;
    sl:warning_high_min "3.8"^^xsd:decimal ;
    sl:warning_high_max "4.0"^^xsd:decimal ;
    sl:fault_low_max "2.5"^^xsd:decimal ;
    sl:fault_high_min "4.0"^^xsd:decimal .

sl:Threshold_spray_width_mm a sl:SensorThreshold ;
    sl:metricName "spray_width_mm" ;
    sl:component "spray_width" ;
    sl:componentZh "噴幅" ;
    sl:unit "mm" ;
    sl:causeId "SPRAY_WIDTH_DEVIATION" ;
    sl:responseIds "ADJUST_TCP_Z|ADJUST_FLOW_PRESSURE|REPLACE_NOZZLE" ;
    sl:description "噴幅寬度偏離安全範圍可能代表流量壓力或噴嘴狀態異常" ;
    sl:belongsTo sl:SprayLineThresholdSet ;
    sl:normal_min "70"^^xsd:decimal ;
    sl:normal_max "130"^^xsd:decimal ;
    sl:warning_low_min "60"^^xsd:decimal ;
    sl:warning_low_max "70"^^xsd:decimal ;
    sl:warning_high_min "130"^^xsd:decimal ;
    sl:warning_high_max "140"^^xsd:decimal ;
    sl:fault_low_max "60"^^xsd:decimal ;
    sl:fault_high_min "140"^^xsd:decimal .

sl:Threshold_filter_diff_pressure_bar a sl:SensorThreshold ;
    sl:metricName "filter_diff_pressure_bar" ;
    sl:component "filter_mesh" ;
    sl:componentZh "濾網" ;
    sl:unit "bar" ;
    sl:causeId "FILTER_CLOG" ;
    sl:responseIds "REPLACE_FILTER|BACKWASH_FILTER" ;
    sl:description "濾網壓差升高代表阻塞風險增加" ;
    sl:belongsTo sl:SprayLineThresholdSet ;
    sl:normal_min "0.1"^^xsd:decimal ;
    sl:normal_max "0.5"^^xsd:decimal ;
    sl:warning_high_min "0.5"^^xsd:decimal ;
    sl:warning_high_max "0.7"^^xsd:decimal ;
    sl:fault_high_min "0.7"^^xsd:decimal .

sl:Threshold_film_thickness_um a sl:SensorThreshold ;
    sl:metricName "film_thickness_um" ;
    sl:component "quality" ;
    sl:componentZh "品質" ;
    sl:unit "um" ;
    sl:causeId "THICKNESS_DRIFT" ;
    sl:responseIds "ADJUST_SPEED_FLOW|CALIBRATE_ENV_CONTROL" ;
    sl:description "膜厚超出管制範圍代表噴塗品質可能不穩" ;
    sl:belongsTo sl:SprayLineThresholdSet ;
    sl:normal_min "13.5"^^xsd:decimal ;
    sl:normal_max "16.5"^^xsd:decimal ;
    sl:warning_low_min "12.5"^^xsd:decimal ;
    sl:warning_low_max "13.5"^^xsd:decimal ;
    sl:warning_high_min "16.5"^^xsd:decimal ;
    sl:warning_high_max "17.5"^^xsd:decimal ;
    sl:fault_low_max "12.5"^^xsd:decimal ;
    sl:fault_high_min "17.5"^^xsd:decimal .

sl:Threshold_paint_flow_ml_min a sl:SensorThreshold ;
    sl:metricName "paint_flow_ml_min" ;
    sl:component "nozzle" ;
    sl:componentZh "噴嘴" ;
    sl:unit "ml/min" ;
    sl:causeId "NOZZLE_CLOG" ;
    sl:responseIds "CLEAN_NOZZLE|REPLACE_NOZZLE" ;
    sl:description "塗料流量偏離正式製程範圍可能代表噴嘴阻塞或供料異常" ;
    sl:belongsTo sl:SprayLineThresholdSet ;
    sl:normal_min "105"^^xsd:decimal ;
    sl:normal_max "125"^^xsd:decimal ;
    sl:warning_low_min "95"^^xsd:decimal ;
    sl:warning_low_max "105"^^xsd:decimal ;
    sl:fault_low_max "95"^^xsd:decimal ;
    sl:fault_high_min "125"^^xsd:decimal .

sl:Threshold_servo_torque_load_pct a sl:SensorThreshold ;
    sl:metricName "servo_torque_load_pct" ;
    sl:component "robot_arm" ;
    sl:componentZh "機械手臂" ;
    sl:unit "%" ;
    sl:causeId "SERVO_WEAR" ;
    sl:responseIds "LUBRICATE_SERVO|REPLACE_SERVO" ;
    sl:description "伺服負載偏離正常範圍可能代表機構阻力或磨耗增加" ;
    sl:belongsTo sl:SprayLineThresholdSet ;
    sl:normal_min "40"^^xsd:decimal ;
    sl:normal_max "60"^^xsd:decimal ;
    sl:warning_low_min "0"^^xsd:decimal ;
    sl:warning_low_max "40"^^xsd:decimal ;
    sl:warning_high_min "60"^^xsd:decimal ;
    sl:warning_high_max "75"^^xsd:decimal ;
    sl:fault_high_min "75"^^xsd:decimal .

sl:Threshold_path_error_mm a sl:SensorThreshold ;
    sl:metricName "path_error_mm" ;
    sl:component "robot_arm" ;
    sl:componentZh "機械手臂" ;
    sl:unit "mm" ;
    sl:causeId "PATH_ERROR_HIGH" ;
    sl:responseIds "RECALIBRATE_TCP" ;
    sl:description "路徑誤差偏高可能影響噴塗位置與品質" ;
    sl:belongsTo sl:SprayLineThresholdSet ;
    sl:normal_min "0"^^xsd:decimal ;
    sl:normal_max "0.1"^^xsd:decimal ;
    sl:warning_high_min "0.1"^^xsd:decimal ;
    sl:warning_high_max "0.15"^^xsd:decimal ;
    sl:fault_high_min "0.15"^^xsd:decimal .

sl:Threshold_temperature_c a sl:SensorThreshold ;
    sl:metricName "temperature_c" ;
    sl:component "environment" ;
    sl:componentZh "環境溫度" ;
    sl:unit "degC" ;
    sl:causeId "ENV_TEMP_OUT" ;
    sl:responseIds "CALIBRATE_ENV_CONTROL" ;
    sl:description "環境溫度超出製程範圍可能影響塗料黏度與成膜品質" ;
    sl:belongsTo sl:SprayLineThresholdSet ;
    sl:normal_min "20"^^xsd:decimal ;
    sl:normal_max "30"^^xsd:decimal ;
    sl:warning_low_min "15"^^xsd:decimal ;
    sl:warning_low_max "20"^^xsd:decimal ;
    sl:warning_high_min "30"^^xsd:decimal ;
    sl:warning_high_max "35"^^xsd:decimal ;
    sl:fault_low_max "15"^^xsd:decimal ;
    sl:fault_high_min "35"^^xsd:decimal .

sl:Threshold_humidity_rh a sl:SensorThreshold ;
    sl:metricName "humidity_rh" ;
    sl:component "environment" ;
    sl:componentZh "環境濕度" ;
    sl:unit "%RH" ;
    sl:causeId "ENV_HUMID_OUT" ;
    sl:responseIds "CALIBRATE_ENV_CONTROL" ;
    sl:description "環境濕度超出製程範圍可能影響附著與乾燥品質" ;
    sl:belongsTo sl:SprayLineThresholdSet ;
    sl:normal_min "45"^^xsd:decimal ;
    sl:normal_max "65"^^xsd:decimal ;
    sl:warning_low_min "35"^^xsd:decimal ;
    sl:warning_low_max "45"^^xsd:decimal ;
    sl:warning_high_min "65"^^xsd:decimal ;
    sl:warning_high_max "75"^^xsd:decimal ;
    sl:fault_low_max "35"^^xsd:decimal ;
    sl:fault_high_min "75"^^xsd:decimal .

sl:Threshold_quality_score_pct a sl:SensorThreshold ;
    sl:metricName "quality_score_pct" ;
    sl:component "quality" ;
    sl:componentZh "製程品質分數" ;
    sl:unit "%" ;
    sl:causeId "THICKNESS_DRIFT" ;
    sl:responseIds "ADJUST_SPEED_FLOW|CALIBRATE_ENV_CONTROL" ;
    sl:description "製程品質分數由流量壓力噴幅與路徑誤差估算並非實際檢驗良品率" ;
    sl:belongsTo sl:SprayLineThresholdSet ;
    sl:normal_min "90"^^xsd:decimal ;
    sl:normal_max "100"^^xsd:decimal ;
    sl:warning_low_min "70"^^xsd:decimal ;
    sl:warning_low_max "90"^^xsd:decimal ;
    sl:fault_low_max "70"^^xsd:decimal .

sl:Threshold_estimated_defect_rate_pct a sl:SensorThreshold ;
    sl:metricName "estimated_defect_rate_pct" ;
    sl:component "quality" ;
    sl:componentZh "估計異常樣本率" ;
    sl:unit "%" ;
    sl:causeId "THICKNESS_DRIFT" ;
    sl:responseIds "ADJUST_SPEED_FLOW|CALIBRATE_ENV_CONTROL" ;
    sl:description "估計異常樣本率超過門檻時應檢查製程條件" ;
    sl:belongsTo sl:SprayLineThresholdSet ;
    sl:normal_min "0"^^xsd:decimal ;
    sl:normal_max "10"^^xsd:decimal ;
    sl:warning_high_min "10"^^xsd:decimal ;
    sl:warning_high_max "30"^^xsd:decimal ;
    sl:fault_high_min "30"^^xsd:decimal .

sl:Threshold_qc_pct a sl:SensorThreshold ;
    sl:metricName "qc_pct" ;
    sl:component "quality" ;
    sl:componentZh "估計異常樣本率" ;
    sl:unit "%" ;
    sl:causeId "THICKNESS_DRIFT" ;
    sl:responseIds "ADJUST_SPEED_FLOW|CALIBRATE_ENV_CONTROL" ;
    sl:description "Qc目前表示估計異常樣本率並非實際產品不良率" ;
    sl:belongsTo sl:SprayLineThresholdSet ;
    sl:normal_min "0"^^xsd:decimal ;
    sl:normal_max "10"^^xsd:decimal ;
    sl:warning_high_min "10"^^xsd:decimal ;
    sl:warning_high_max "30"^^xsd:decimal ;
    sl:fault_high_min "30"^^xsd:decimal .

sl:Threshold_estimated_film_thickness_um a sl:SensorThreshold ;
    sl:metricName "estimated_film_thickness_um" ;
    sl:component "quality" ;
    sl:componentZh "估計膜厚" ;
    sl:unit "um" ;
    sl:causeId "THICKNESS_DRIFT" ;
    sl:responseIds "ADJUST_SPEED_FLOW|CALIBRATE_ENV_CONTROL" ;
    sl:description "估計膜厚超出管制範圍時應檢查流量噴幅與環境條件" ;
    sl:belongsTo sl:SprayLineThresholdSet ;
    sl:normal_min "13.5"^^xsd:decimal ;
    sl:normal_max "16.5"^^xsd:decimal ;
    sl:warning_low_min "12.5"^^xsd:decimal ;
    sl:warning_low_max "13.5"^^xsd:decimal ;
    sl:warning_high_min "16.5"^^xsd:decimal ;
    sl:warning_high_max "17.5"^^xsd:decimal ;
    sl:fault_low_max "12.5"^^xsd:decimal ;
    sl:fault_high_min "17.5"^^xsd:decimal .
