@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix spray: <http://nkust.edu.tw/mislab/spraying/ontology#> .
spray:CoreOntology a owl:Ontology .
spray:SprayLineProjectConcept a owl:Class ; rdfs:label "噴塗產線專案概念"@zh .
spray:SprayLine a owl:Class ; rdfs:label "噴塗產線"@zh ; rdfs:subClassOf spray:SprayLineProjectConcept .
spray:Station a owl:Class ; rdfs:label "作業站點"@zh ; rdfs:subClassOf spray:SprayLineProjectConcept .
spray:PhysicalAsset a owl:Class ; rdfs:label "實體資產"@zh ; rdfs:subClassOf spray:SprayLineProjectConcept .
spray:SensorSignal a owl:Class ; rdfs:label "感測訊號"@zh ; rdfs:subClassOf spray:SprayLineProjectConcept .
spray:BatchRecord a owl:Class ; rdfs:label "批次紀錄"@zh ; rdfs:subClassOf spray:SprayLineProjectConcept .
spray:DataQualityFlag a owl:Class ; rdfs:label "資料品質標記"@zh ; rdfs:subClassOf spray:SprayLineProjectConcept .
spray:RobotArm a owl:Class ; rdfs:label "機械手臂"@zh ; rdfs:subClassOf spray:PhysicalAsset .
spray:Nozzle a owl:Class ; rdfs:label "噴嘴"@zh ; rdfs:subClassOf spray:PhysicalAsset .
spray:FilterMesh a owl:Class ; rdfs:label "濾網"@zh ; rdfs:subClassOf spray:PhysicalAsset .
spray:AirCompressor a owl:Class ; rdfs:label "空壓機"@zh ; rdfs:subClassOf spray:PhysicalAsset .
spray:SprayWidth a owl:Class ; rdfs:label "噴幅"@zh ; rdfs:subClassOf spray:PhysicalAsset .
spray:QualityModule a owl:Class ; rdfs:label "品質模組"@zh ; rdfs:subClassOf spray:PhysicalAsset .
spray:Oven a owl:Class ; rdfs:label "烤箱"@zh ; rdfs:subClassOf spray:PhysicalAsset .
spray:OneMinuteSignal a owl:Class ; rdfs:label "一分鐘感測訊號"@zh ; rdfs:subClassOf spray:SensorSignal .
spray:ThreeMinuteSignal a owl:Class ; rdfs:label "三分鐘感測訊號"@zh ; rdfs:subClassOf spray:SensorSignal .
spray:RobotArmSignal a owl:Class ; rdfs:label "機械手臂訊號"@zh ; rdfs:subClassOf spray:OneMinuteSignal .
spray:NozzleSignal a owl:Class ; rdfs:label "噴嘴訊號"@zh ; rdfs:subClassOf spray:OneMinuteSignal .
spray:FilterSignal a owl:Class ; rdfs:label "濾網訊號"@zh ; rdfs:subClassOf spray:OneMinuteSignal .
spray:AirPressureSignal a owl:Class ; rdfs:label "空壓訊號"@zh ; rdfs:subClassOf spray:OneMinuteSignal .
spray:ProcessSignal a owl:Class ; rdfs:label "製程訊號"@zh ; rdfs:subClassOf spray:OneMinuteSignal .
spray:QualitySignal a owl:Class ; rdfs:label "品質訊號"@zh ; rdfs:subClassOf spray:OneMinuteSignal .
spray:EnvironmentSignal a owl:Class ; rdfs:label "環境訊號"@zh ; rdfs:subClassOf spray:ThreeMinuteSignal .
spray:hasAsset a owl:ObjectProperty ; rdfs:label "具有資產"@zh ; rdfs:domain spray:Station ; rdfs:range spray:PhysicalAsset .
spray:belongsToStation a owl:ObjectProperty ; rdfs:label "屬於站點"@zh ; rdfs:domain spray:PhysicalAsset ; rdfs:range spray:Station .
spray:observesSignal a owl:ObjectProperty ; rdfs:label "觀測訊號"@zh ; rdfs:domain spray:PhysicalAsset ; rdfs:range spray:SensorSignal .
spray:upstreamOf a owl:ObjectProperty ; rdfs:label "位於上游"@zh ; rdfs:domain spray:PhysicalAsset ; rdfs:range spray:PhysicalAsset .
spray:affectsDownstream a owl:ObjectProperty ; rdfs:label "影響下游"@zh ; rdfs:domain spray:PhysicalAsset ; rdfs:range spray:PhysicalAsset .
spray:hasDataQualityFlag a owl:ObjectProperty ; rdfs:label "具有資料品質標記"@zh ; rdfs:domain spray:SensorSignal ; rdfs:range spray:DataQualityFlag .
spray:signalName a owl:DatatypeProperty ; rdfs:label "訊號名稱"@zh ; rdfs:domain spray:SensorSignal ; rdfs:range xsd:string .
spray:stationCode a owl:DatatypeProperty ; rdfs:label "站點代碼"@zh ; rdfs:domain spray:Station ; rdfs:range xsd:string .
spray:Station_1 a owl:Class, owl:NamedIndividual ; rdfs:label "Station_1"@zh ; rdfs:subClassOf spray:Station ; spray:stationCode "Station_1" .
spray:Station_2 a owl:Class, owl:NamedIndividual ; rdfs:label "Station_2"@zh ; rdfs:subClassOf spray:Station ; spray:stationCode "Station_2" .
spray:Station_3 a owl:Class, owl:NamedIndividual ; rdfs:label "Station_3"@zh ; rdfs:subClassOf spray:Station ; spray:stationCode "Station_3" .
spray:Station_1_RobotArm a owl:Class, owl:NamedIndividual ; rdfs:label "Station_1／機械手臂"@zh ; rdfs:subClassOf spray:RobotArm ; spray:belongsToStation spray:Station_1 .
spray:Station_1_Nozzle a owl:Class, owl:NamedIndividual ; rdfs:label "Station_1／噴嘴"@zh ; rdfs:subClassOf spray:Nozzle ; spray:belongsToStation spray:Station_1 ; spray:upstreamOf spray:Station_1_SprayWidth ; spray:affectsDownstream spray:Station_1_Oven .
spray:Station_1_FilterMesh a owl:Class, owl:NamedIndividual ; rdfs:label "Station_1／濾網"@zh ; rdfs:subClassOf spray:FilterMesh ; spray:belongsToStation spray:Station_1 ; spray:upstreamOf spray:Station_1_Nozzle ; spray:affectsDownstream spray:Station_1_Oven .
spray:Station_1_AirCompressor a owl:Class, owl:NamedIndividual ; rdfs:label "Station_1／空壓機"@zh ; rdfs:subClassOf spray:AirCompressor ; spray:belongsToStation spray:Station_1 ; spray:upstreamOf spray:Station_1_Nozzle ; spray:affectsDownstream spray:Station_1_Oven .
spray:Station_1_SprayWidth a owl:Class, owl:NamedIndividual ; rdfs:label "Station_1／噴幅"@zh ; rdfs:subClassOf spray:SprayWidth ; spray:belongsToStation spray:Station_1 ; spray:upstreamOf spray:Station_1_QualityModule ; spray:affectsDownstream spray:Station_1_Oven .
spray:Station_1_QualityModule a owl:Class, owl:NamedIndividual ; rdfs:label "Station_1／品質模組"@zh ; rdfs:subClassOf spray:QualityModule ; spray:belongsToStation spray:Station_1 ; spray:upstreamOf spray:Station_1_Oven .
spray:Station_1_Oven a owl:Class, owl:NamedIndividual ; rdfs:label "Station_1／烤箱"@zh ; rdfs:subClassOf spray:Oven ; spray:belongsToStation spray:Station_1 .
spray:Station_1 spray:hasAsset spray:Station_1_RobotArm, spray:Station_1_Nozzle, spray:Station_1_FilterMesh, spray:Station_1_AirCompressor, spray:Station_1_SprayWidth, spray:Station_1_QualityModule, spray:Station_1_Oven .
spray:Station_2_RobotArm a owl:Class, owl:NamedIndividual ; rdfs:label "Station_2／機械手臂"@zh ; rdfs:subClassOf spray:RobotArm ; spray:belongsToStation spray:Station_2 .
spray:Station_2_Nozzle a owl:Class, owl:NamedIndividual ; rdfs:label "Station_2／噴嘴"@zh ; rdfs:subClassOf spray:Nozzle ; spray:belongsToStation spray:Station_2 ; spray:upstreamOf spray:Station_2_SprayWidth ; spray:affectsDownstream spray:Station_2_Oven .
spray:Station_2_FilterMesh a owl:Class, owl:NamedIndividual ; rdfs:label "Station_2／濾網"@zh ; rdfs:subClassOf spray:FilterMesh ; spray:belongsToStation spray:Station_2 ; spray:upstreamOf spray:Station_2_Nozzle ; spray:affectsDownstream spray:Station_2_Oven .
spray:Station_2_AirCompressor a owl:Class, owl:NamedIndividual ; rdfs:label "Station_2／空壓機"@zh ; rdfs:subClassOf spray:AirCompressor ; spray:belongsToStation spray:Station_2 ; spray:upstreamOf spray:Station_2_Nozzle ; spray:affectsDownstream spray:Station_2_Oven .
spray:Station_2_SprayWidth a owl:Class, owl:NamedIndividual ; rdfs:label "Station_2／噴幅"@zh ; rdfs:subClassOf spray:SprayWidth ; spray:belongsToStation spray:Station_2 ; spray:upstreamOf spray:Station_2_QualityModule ; spray:affectsDownstream spray:Station_2_Oven .
spray:Station_2_QualityModule a owl:Class, owl:NamedIndividual ; rdfs:label "Station_2／品質模組"@zh ; rdfs:subClassOf spray:QualityModule ; spray:belongsToStation spray:Station_2 ; spray:upstreamOf spray:Station_2_Oven .
spray:Station_2_Oven a owl:Class, owl:NamedIndividual ; rdfs:label "Station_2／烤箱"@zh ; rdfs:subClassOf spray:Oven ; spray:belongsToStation spray:Station_2 .
spray:Station_2 spray:hasAsset spray:Station_2_RobotArm, spray:Station_2_Nozzle, spray:Station_2_FilterMesh, spray:Station_2_AirCompressor, spray:Station_2_SprayWidth, spray:Station_2_QualityModule, spray:Station_2_Oven .
spray:Station_3_RobotArm a owl:Class, owl:NamedIndividual ; rdfs:label "Station_3／機械手臂"@zh ; rdfs:subClassOf spray:RobotArm ; spray:belongsToStation spray:Station_3 .
spray:Station_3_Nozzle a owl:Class, owl:NamedIndividual ; rdfs:label "Station_3／噴嘴"@zh ; rdfs:subClassOf spray:Nozzle ; spray:belongsToStation spray:Station_3 ; spray:upstreamOf spray:Station_3_SprayWidth ; spray:affectsDownstream spray:Station_3_Oven .
spray:Station_3_FilterMesh a owl:Class, owl:NamedIndividual ; rdfs:label "Station_3／濾網"@zh ; rdfs:subClassOf spray:FilterMesh ; spray:belongsToStation spray:Station_3 ; spray:upstreamOf spray:Station_3_Nozzle ; spray:affectsDownstream spray:Station_3_Oven .
spray:Station_3_AirCompressor a owl:Class, owl:NamedIndividual ; rdfs:label "Station_3／空壓機"@zh ; rdfs:subClassOf spray:AirCompressor ; spray:belongsToStation spray:Station_3 ; spray:upstreamOf spray:Station_3_Nozzle ; spray:affectsDownstream spray:Station_3_Oven .
spray:Station_3_SprayWidth a owl:Class, owl:NamedIndividual ; rdfs:label "Station_3／噴幅"@zh ; rdfs:subClassOf spray:SprayWidth ; spray:belongsToStation spray:Station_3 ; spray:upstreamOf spray:Station_3_QualityModule ; spray:affectsDownstream spray:Station_3_Oven .
spray:Station_3_QualityModule a owl:Class, owl:NamedIndividual ; rdfs:label "Station_3／品質模組"@zh ; rdfs:subClassOf spray:QualityModule ; spray:belongsToStation spray:Station_3 ; spray:upstreamOf spray:Station_3_Oven .
spray:Station_3_Oven a owl:Class, owl:NamedIndividual ; rdfs:label "Station_3／烤箱"@zh ; rdfs:subClassOf spray:Oven ; spray:belongsToStation spray:Station_3 .
spray:Station_3 spray:hasAsset spray:Station_3_RobotArm, spray:Station_3_Nozzle, spray:Station_3_FilterMesh, spray:Station_3_AirCompressor, spray:Station_3_SprayWidth, spray:Station_3_QualityModule, spray:Station_3_Oven .
spray:film_thickness_um a owl:Class, owl:NamedIndividual ; rdfs:label "film_thickness_um（膜厚）"@zh ; rdfs:subClassOf spray:QualitySignal ; spray:signalName "film_thickness_um" .
spray:paint_flow_ml_min a owl:Class, owl:NamedIndividual ; rdfs:label "paint_flow_ml_min（塗料流量）"@zh ; rdfs:subClassOf spray:ProcessSignal ; spray:signalName "paint_flow_ml_min" .
spray:nozzle_roll a owl:Class, owl:NamedIndividual ; rdfs:label "nozzle_roll（噴嘴翻滾角）"@zh ; rdfs:subClassOf spray:NozzleSignal ; spray:signalName "nozzle_roll" .
spray:filter_diff_pressure_bar a owl:Class, owl:NamedIndividual ; rdfs:label "filter_diff_pressure_bar（濾網壓差）"@zh ; rdfs:subClassOf spray:FilterSignal ; spray:signalName "filter_diff_pressure_bar" .
spray:filter_inflow_ml_min a owl:Class, owl:NamedIndividual ; rdfs:label "filter_inflow_ml_min（濾網入口流量）"@zh ; rdfs:subClassOf spray:FilterSignal ; spray:signalName "filter_inflow_ml_min" .
spray:filter_outflow_ml_min a owl:Class, owl:NamedIndividual ; rdfs:label "filter_outflow_ml_min（濾網出口流量）"@zh ; rdfs:subClassOf spray:FilterSignal ; spray:signalName "filter_outflow_ml_min" .
spray:pump_current_a a owl:Class, owl:NamedIndividual ; rdfs:label "pump_current_a（上游資料欄位）"@zh ; rdfs:subClassOf spray:ProcessSignal ; spray:signalName "pump_current_a" .
spray:air_pressure_bar a owl:Class, owl:NamedIndividual ; rdfs:label "air_pressure_bar（空氣壓力）"@zh ; rdfs:subClassOf spray:AirPressureSignal ; spray:signalName "air_pressure_bar" .
spray:spray_width_mm a owl:Class, owl:NamedIndividual ; rdfs:label "spray_width_mm（噴幅寬度）"@zh ; rdfs:subClassOf spray:ProcessSignal ; spray:signalName "spray_width_mm" .
spray:servo_torque_load_pct a owl:Class, owl:NamedIndividual ; rdfs:label "servo_torque_load_pct（伺服負載）"@zh ; rdfs:subClassOf spray:RobotArmSignal ; spray:signalName "servo_torque_load_pct" .
spray:path_error_mm a owl:Class, owl:NamedIndividual ; rdfs:label "path_error_mm（軌跡追隨誤差）"@zh ; rdfs:subClassOf spray:RobotArmSignal ; spray:signalName "path_error_mm" .
spray:vibration_g a owl:Class, owl:NamedIndividual ; rdfs:label "vibration_g（振動）"@zh ; rdfs:subClassOf spray:RobotArmSignal ; spray:signalName "vibration_g" .
spray:tcp_x_mm a owl:Class, owl:NamedIndividual ; rdfs:label "tcp_x_mm"@zh ; rdfs:subClassOf spray:RobotArmSignal ; spray:signalName "tcp_x_mm" .
spray:tcp_y_mm a owl:Class, owl:NamedIndividual ; rdfs:label "tcp_y_mm"@zh ; rdfs:subClassOf spray:RobotArmSignal ; spray:signalName "tcp_y_mm" .
spray:tcp_z_mm a owl:Class, owl:NamedIndividual ; rdfs:label "tcp_z_mm"@zh ; rdfs:subClassOf spray:RobotArmSignal ; spray:signalName "tcp_z_mm" .
spray:speed_mm_s a owl:Class, owl:NamedIndividual ; rdfs:label "speed_mm_s"@zh ; rdfs:subClassOf spray:RobotArmSignal ; spray:signalName "speed_mm_s" .
spray:gearbox_temperature_c a owl:Class, owl:NamedIndividual ; rdfs:label "gearbox_temperature_c（減速機溫度）"@zh ; rdfs:subClassOf spray:EnvironmentSignal ; spray:signalName "gearbox_temperature_c" .
spray:temperature_c a owl:Class, owl:NamedIndividual ; rdfs:label "temperature_c（環境溫度）"@zh ; rdfs:subClassOf spray:EnvironmentSignal ; spray:signalName "temperature_c" .
spray:humidity_rh a owl:Class, owl:NamedIndividual ; rdfs:label "humidity_rh（環境濕度）"@zh ; rdfs:subClassOf spray:EnvironmentSignal ; spray:signalName "humidity_rh" .
spray:FilterMesh spray:observesSignal spray:filter_diff_pressure_bar, spray:filter_inflow_ml_min, spray:filter_outflow_ml_min .
spray:AirCompressor spray:observesSignal spray:air_pressure_bar .
spray:Nozzle spray:observesSignal spray:nozzle_roll, spray:paint_flow_ml_min .
spray:SprayWidth spray:observesSignal spray:spray_width_mm .
spray:QualityModule spray:observesSignal spray:film_thickness_um .
spray:RobotArm spray:observesSignal spray:servo_torque_load_pct, spray:path_error_mm, spray:vibration_g, spray:tcp_x_mm, spray:tcp_y_mm, spray:tcp_z_mm, spray:speed_mm_s, spray:gearbox_temperature_c .
spray:NormalDataQuality a owl:Class, owl:NamedIndividual ; rdfs:label "正常資料品質"@zh ; rdfs:subClassOf spray:DataQualityFlag .
spray:InterpolatedDataQuality a owl:Class, owl:NamedIndividual ; rdfs:label "補值資料品質"@zh ; rdfs:subClassOf spray:DataQualityFlag .
