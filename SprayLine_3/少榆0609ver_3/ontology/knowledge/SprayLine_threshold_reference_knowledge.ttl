spray:TH_AIR_PRESSURE_ALL a spray:SensorThresholdReference, owl:NamedIndividual ;
    rdfs:label "air_pressure_bar / ALL 門檻參考"@zh ;
    spray:appliesToSignal spray:air_pressure_bar ;
    spray:normalMin ">=1.5" ;
    spray:alarmMin "<1.5" ;
    spray:thresholdUnit "bar" ;
    spray:thresholdLogic "low_limit" ;
    spray:thresholdSource "DataPreprocess_LinShengYao" ;
    spray:thresholdStatus "preprocess_reference_pending_confirmation" .

