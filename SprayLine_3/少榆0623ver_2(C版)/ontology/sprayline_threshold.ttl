@prefix sl: <http://example.org/sprayline#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .


sl:SprayLineThresholdSet a sl:ThresholdSet ;
    sl:sourceFile "ontology/threshold_reference.csv" ;
    sl:version "0623ver_2" .

sl:Threshold_air_pressure_bar a sl:SensorThreshold ;
    sl:metricName "air_pressure_bar" ;
    sl:component "air_compressor" ;
    sl:componentZh "空壓機" ;
    sl:unit "bar" ;
    sl:causeId "AIR_PRESSURE_UNSTABLE" ;
    sl:responseIds "CALIBRATE_PRESSURE_VALVE" ;
    sl:description "空壓機壓力過低或過高會造成霧化不穩與噴塗不均" ;
    sl:belongsTo sl:SprayLineThresholdSet ;
    sl:normal_min "2.7"^^xsd:decimal ;
    sl:normal_max "3.8"^^xsd:decimal ;
    sl:warning_low_min "2.5"^^xsd:decimal ;
    sl:warning_low_max "2.7"^^xsd:decimal ;
    sl:warning_high_min "3.8"^^xsd:decimal ;
    sl:warning_high_max "4.0"^^xsd:decimal ;
    sl:fault_low_max "2.5"^^xsd:decimal ;
    sl:fault_high_min "4.0"^^xsd:decimal .

sl:Threshold_spray_width_mm a sl:SensorThreshold ;
    sl:metricName "spray_width_mm" ;
    sl:component "spray_width" ;
    sl:componentZh "噴幅" ;
    sl:unit "mm" ;
    sl:causeId "SPRAY_WIDTH_DEVIATION" ;
    sl:responseIds "ADJUST_FLOW_PRESSURE|INSPECT_NOZZLE" ;
    sl:description "噴幅寬度偏離正常範圍可能代表流量壓力或噴嘴狀態異常" ;
    sl:belongsTo sl:SprayLineThresholdSet ;
    sl:normal_min "70"^^xsd:decimal ;
    sl:normal_max "130"^^xsd:decimal ;
    sl:warning_low_min "60"^^xsd:decimal ;
    sl:warning_low_max "70"^^xsd:decimal ;
    sl:warning_high_min "130"^^xsd:decimal ;
    sl:warning_high_max "140"^^xsd:decimal ;
    sl:fault_low_max "60"^^xsd:decimal ;
    sl:fault_high_min "140"^^xsd:decimal .

sl:Threshold_filter_diff_pressure_bar a sl:SensorThreshold ;
    sl:metricName "filter_diff_pressure_bar" ;
    sl:component "filter_mesh" ;
    sl:componentZh "濾網" ;
    sl:unit "bar" ;
    sl:causeId "FILTER_CLOG" ;
    sl:responseIds "CHECK_FILTER|REPLACE_FILTER" ;
    sl:description "濾網壓差升高代表阻塞風險增加" ;
    sl:belongsTo sl:SprayLineThresholdSet ;
    sl:normal_min "0.1"^^xsd:decimal ;
    sl:normal_max "0.5"^^xsd:decimal ;
    sl:warning_high_min "0.5"^^xsd:decimal ;
    sl:warning_high_max "0.7"^^xsd:decimal ;
    sl:fault_high_min "0.7"^^xsd:decimal .

sl:Threshold_film_thickness_um a sl:SensorThreshold ;
    sl:metricName "film_thickness_um" ;
    sl:component "quality" ;
    sl:componentZh "品質" ;
    sl:unit "um" ;
    sl:causeId "FILM_THICKNESS_OOC" ;
    sl:responseIds "ADJUST_FILM_THICKNESS|ADJUST_FLOW_PRESSURE" ;
    sl:description "膜厚超出管制範圍代表噴塗品質可能不穩" ;
    sl:belongsTo sl:SprayLineThresholdSet ;
    sl:normal_min "13.5"^^xsd:decimal ;
    sl:normal_max "16.5"^^xsd:decimal ;
    sl:warning_low_min "12.5"^^xsd:decimal ;
    sl:warning_low_max "13.5"^^xsd:decimal ;
    sl:warning_high_min "16.5"^^xsd:decimal ;
    sl:warning_high_max "17.5"^^xsd:decimal ;
    sl:fault_low_max "12.5"^^xsd:decimal ;
    sl:fault_high_min "17.5"^^xsd:decimal .

sl:Threshold_paint_flow_ml_min a sl:SensorThreshold ;
    sl:metricName "paint_flow_ml_min" ;
    sl:component "nozzle" ;
    sl:componentZh "噴嘴" ;
    sl:unit "ml/min" ;
    sl:causeId "FLOW_IMBALANCE" ;
    sl:responseIds "ADJUST_FLOW_PRESSURE|INSPECT_NOZZLE" ;
    sl:description "塗料流量過低或過高會影響噴幅與膜厚穩定性" ;
    sl:belongsTo sl:SprayLineThresholdSet ;
    sl:normal_min "80"^^xsd:decimal ;
    sl:normal_max "130"^^xsd:decimal ;
    sl:warning_low_min "60"^^xsd:decimal ;
    sl:warning_low_max "80"^^xsd:decimal ;
    sl:warning_high_min "130"^^xsd:decimal ;
    sl:warning_high_max "150"^^xsd:decimal ;
    sl:fault_low_max "60"^^xsd:decimal ;
    sl:fault_high_min "150"^^xsd:decimal .

sl:Threshold_servo_torque_load_pct a sl:SensorThreshold ;
    sl:metricName "servo_torque_load_pct" ;
    sl:component "robot_arm" ;
    sl:componentZh "機械手臂" ;
    sl:unit "%" ;
    sl:causeId "SERVO_WEAR" ;
    sl:responseIds "CHECK_SERVO|REDUCE_SPEED" ;
    sl:description "伺服負載升高可能代表機構阻力或磨耗增加" ;
    sl:belongsTo sl:SprayLineThresholdSet ;
    sl:normal_min "0"^^xsd:decimal ;
    sl:normal_max "55"^^xsd:decimal ;
    sl:warning_high_min "55"^^xsd:decimal ;
    sl:warning_high_max "70"^^xsd:decimal ;
    sl:fault_high_min "70"^^xsd:decimal .

sl:Threshold_path_error_mm a sl:SensorThreshold ;
    sl:metricName "path_error_mm" ;
    sl:component "robot_arm" ;
    sl:componentZh "機械手臂" ;
    sl:unit "mm" ;
    sl:causeId "PATH_ERROR_HIGH" ;
    sl:responseIds "CCD_PATH_CORRECTION" ;
    sl:description "路徑誤差偏高可能影響噴塗位置與品質" ;
    sl:belongsTo sl:SprayLineThresholdSet ;
    sl:normal_min "0"^^xsd:decimal ;
    sl:normal_max "0.8"^^xsd:decimal ;
    sl:warning_high_min "0.8"^^xsd:decimal ;
    sl:warning_high_max "1.5"^^xsd:decimal ;
    sl:fault_high_min "1.5"^^xsd:decimal .
