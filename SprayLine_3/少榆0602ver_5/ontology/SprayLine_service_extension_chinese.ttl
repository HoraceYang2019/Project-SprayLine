@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix spray: <http://nkust.edu.tw/mislab/spraying/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

spray:APIGateway a owl:Class ;
    rdfs:label "API Gateway"@zh ;
    rdfs:subClassOf spray:Infrastructure .

spray:DashboardV15 a spray:DashboardV15Interface,
        owl:NamedIndividual ;
    rdfs:label "Dashboard v15 介面"@zh ;
    spray:hasUIComponent spray:BatchTable,
        spray:ComponentDiagnosisDrawer,
        spray:KPICards,
        spray:PendingAlertsDrawer,
        spray:PredictionAccuracyDrawer,
        spray:QualityUtilizationCycleCharts,
        spray:StationCards6Components,
        spray:StationSummaryCards,
        spray:StatusBanner,
        spray:TimeSeriesSlider,
        spray:YieldComparisonChart .

spray:EngineerMonitoringTab a owl:Class ;
    rdfs:label "即時監控頁籤"@zh ;
