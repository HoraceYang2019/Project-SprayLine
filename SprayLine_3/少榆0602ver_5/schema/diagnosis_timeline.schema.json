{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Diagnosis Timeline Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "line_id",
    "category",
    "start_time",
    "end_time",
    "events",
    "cache_ttl_s"
  ],
  "properties": {
    "line_id": {
      "type": "string",
      "enum": [
        "line_1",
        "line_2",
        "line_3"
      ]
    },
    "category": {
      "type": "string"
    },
    "start_time": {
      "type": "string"
    },
    "end_time": {
      "type": "string"
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "cache_ttl_s": {
      "type": "integer"
    }
  }
}
