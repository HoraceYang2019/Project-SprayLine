{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pending Alerts Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "line_id",
    "total",
    "alerts"
  ],
  "properties": {
    "line_id": {
      "type": "string",
      "enum": [
        "line_1",
        "line_2",
        "line_3"
      ]
    },
    "total": {
      "type": "integer"
    },
    "alerts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  }
}
