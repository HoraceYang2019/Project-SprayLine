{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Line Summary Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "line_id",
    "timestamp",
    "total",
    "normal",
    "warning",
    "predict_risk",
    "cache_ttl_s"
  ],
  "properties": {
    "line_id": {
      "type": "string",
      "enum": [
        "line_1",
        "line_2",
        "line_3"
      ]
    },
    "timestamp": {
      "type": "string"
    },
    "total": {
      "type": "integer"
    },
    "normal": {
      "type": "integer"
    },
    "warning": {
      "type": "integer"
    },
    "predict_risk": {
      "type": "integer"
    },
    "cache_ttl_s": {
      "type": "integer"
    }
  }
}
