{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Omniverse Validation Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "part_uuid",
    "sync_log",
    "trajectory_result",
    "source_tables"
  ],
  "properties": {
    "part_uuid": {
      "type": "string"
    },
    "sync_log": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "trajectory_result": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "source_tables": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
