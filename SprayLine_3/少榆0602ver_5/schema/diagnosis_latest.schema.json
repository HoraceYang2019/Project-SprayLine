{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Diagnosis Latest Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "line_id",
    "diagnoses",
    "threshold_sources",
    "cache_ttl_s"
  ],
  "properties": {
    "line_id": {
      "type": "string",
      "enum": [
        "line_1",
        "line_2",
        "line_3"
      ]
    },
    "diagnoses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "threshold_sources": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "filter_threshold",
          "nozzle_threshold",
          "process_threshold"
        ]
      }
    },
    "cache_ttl_s": {
      "type": "integer"
    }
  }
}
