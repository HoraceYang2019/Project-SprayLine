{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Station Latest Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "line_id",
    "window_id",
    "signal",
    "reference",
    "metric",
    "pose",
    "components",
    "cache_ttl_s"
  ],
  "properties": {
    "line_id": {
      "type": "string",
      "enum": [
        "line_1",
        "line_2",
        "line_3"
      ]
    },
    "window_id": {
      "type": "string"
    },
    "signal": {
      "type": "object",
      "additionalProperties": true
    },
    "reference": {
      "type": "object",
      "additionalProperties": true
    },
    "metric": {
      "type": "object",
      "additionalProperties": true
    },
    "pose": {
      "type": "object",
      "additionalProperties": true
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "cache_ttl_s": {
      "type": "integer"
    }
  }
}
