{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Metric Trend Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "line_id",
    "metric_name",
    "points",
    "time_range",
    "cache_ttl_s"
  ],
  "properties": {
    "line_id": {
      "type": "string",
      "enum": [
        "line_1",
        "line_2",
        "line_3"
      ]
    },
    "metric_name": {
      "type": "string"
    },
    "points": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "time_range": {
      "type": "object",
      "additionalProperties": true
    },
    "cache_ttl_s": {
      "type": "integer"
    }
  }
}
