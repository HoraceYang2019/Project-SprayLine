        owl:NamedIndividual ;
    rdfs:label "濾網異常模板"@zh ;
    spray:affectsDownstreamStep spray:BakingStep01 ;
    spray:affectsFinalResult spray:BakingResultTemplate .

spray:FlowLossFormula a spray:CalculationFormula,
        owl:NamedIndividual ;
    rdfs:label "flow_loss_pct 公式"@zh ;
    spray:fieldKey "flow_loss_pct" ;
    spray:formulaExpression "max(0, (in_flow_ml_min - out_flow_ml_min) / in_flow_ml_min * 100)" ;
    spray:sourceStatus "TimeSeriesService0531_calculation_rule" .

