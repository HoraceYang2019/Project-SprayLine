spray:LineClogRateFormula a spray:CalculationFormula,
        owl:NamedIndividual ;
    rdfs:label "clog_rate_pct 公式"@zh ;
    spray:fieldKey "clog_rate_pct" ;
    spray:formulaExpression "max(nozzle_clog_rate_pct, filter_clog_rate_pct)" ;
    spray:sourceStatus "TimeSeriesService0531_calculation_rule" .

spray:LineMaintainabilityFormula a spray:CalculationFormula,
        owl:NamedIndividual ;
    rdfs:label "maintainability_pct 公式"@zh ;
    spray:fieldKey "maintainability_pct" ;
    spray:formulaExpression "min(nozzle_maintainability_pct, filter_maintainability_pct)" ;
    spray:sourceStatus "TimeSeriesService0531_calculation_rule" .

spray:LineScope a spray:AppliesToScope,
        owl:Class,
        owl:NamedIndividual ;
    rdfs:label "產線範圍"@zh .

spray:MaintainabilityFormula a spray:CalculationFormula,
        owl:NamedIndividual ;
    rdfs:label "maintainability_pct 公式"@zh ;
    spray:fieldKey "maintainability_pct" ;
    spray:formulaExpression "rul_hr / (rul_hr + usage_time_hr) * 100" ;
    spray:sourceStatus "TimeSeriesService0531_calculation_rule" .

spray:MetricScope a spray:AppliesToScope,
        owl:NamedIndividual .

spray:NozzleClogRateFormula a spray:CalculationFormula,
        owl:NamedIndividual ;
    rdfs:label "nozzle_clog_rate_pct 公式"@zh ;
    spray:fieldKey "nozzle_clog_rate_pct" ;
    spray:formulaExpression "max(0, (nominal_flow_rate_ml_min - flow_rate_ml_min) / nominal_flow_rate_ml_min * 100)" ;
    spray:sourceStatus "TimeSeriesService0531_calculation_rule" .

