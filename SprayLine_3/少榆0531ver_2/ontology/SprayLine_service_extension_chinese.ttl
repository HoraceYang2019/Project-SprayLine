spray:TimeSeriesService0531 a spray:TimeSeriesService,
        owl:NamedIndividual ;
    rdfs:label "0531 時間序列服務"@zh ;
    spray:hasSamplingMethod spray:CurrentRecentAverageSampleMethod,
        spray:FutureLatestValidSampleMethod,
        spray:PastMeanSampleMethod ;
    spray:produces spray:AvailabilityFormula,
        spray:CycleTimeFormula,
        spray:FlowLossFormula,
        spray:LineClogRateFormula,
        spray:LineMaintainabilityFormula,
        spray:MaintainabilityFormula,
        spray:NozzleClogRateFormula,
        spray:QualityScoreFormula,
        spray:SprayWidthCoverageFormula,
        spray:UtilizationFormula ;
    spray:queriesDatabase spray:GetComponentHealthSummary,
        spray:GetDiagnosisTimeline,
        spray:GetLatestDiagnosis,
        spray:GetLatestPrediction,
        spray:GetLatestRuntimeWindow,
        spray:GetMetricTrend,
        spray:GetMlFeatureInput,
        spray:GetOmniverseValidationResult,
        spray:GetRecentQualityTrend,
        spray:GetRuntimeWindow,
        spray:GetStationDashboardStatus ;
    spray:sourceStatus "integrated_from_Project_SprayLine_main_0531" ;
    spray:usesFunction spray:ApplySampleMethodsFunction,
        spray:BuildLineOutputFunction,
        spray:BuildOutputFunction,
        spray:CalculateFilterMetricsFunction,
        spray:CalculateLineMetricsFunction,
        spray:CalculateNozzleMetricsFunction,
        spray:CalculateSprayWidthMetricsFunction,
        spray:DetermineTimeTypeFunction,
        spray:GetSampleMethodFunction,
        spray:HandleTimeSeriesQueryFunction,
        spray:QueryDataFunction,
        spray:ResolveLineScopeFunction .

