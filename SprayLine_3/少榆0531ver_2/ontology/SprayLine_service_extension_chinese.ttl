spray:StatisticsService a spray:StatisticsService,
        owl:Class,
        owl:NamedIndividual ;
    rdfs:label "統計服務"@zh ;
    spray:aggregatesCurrentSnapshot spray:CurrentSnapshotLine1W002,
        spray:CurrentSnapshotLine2W002,
        spray:CurrentSnapshotLine3W002 ;
    spray:aggregatesPastSnapshot spray:PastSnapshotLine1W001,
        spray:PastSnapshotLine2W001,
        spray:PastSnapshotLine3W001 ;
    spray:hasDownstreamInterface spray:UIEDashboard01 ;
    spray:hasDownstreamService spray:OntologyService01,
        spray:RuntimeTTLGenerator01,
        spray:UIService01 ;
    spray:hasOutput spray:DashboardSnapshot001 ;
    spray:hasUpstreamService spray:CurrentService01,
        spray:FutureService01,
        spray:PastService01 ;
    spray:hasWindowPolicy spray:StatisticsWindowPolicyFollowContract ;
    spray:produces spray:DashboardSnapshot001,
        spray:LineSummary001,
        spray:StatisticsSummaryLine1W004,
        spray:StatisticsSummaryLine2W004,
        spray:StatisticsSummaryLine3W004,
        spray:TrendSeries001 ;
