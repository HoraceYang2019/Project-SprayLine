spray:AlarmRuleTemplate a spray:AlarmRule,
        owl:NamedIndividual ;
    spray:sourceFilePath "02_統計Service/05_threshold-config/threshold_config.template.json" .

spray:AvailabilityFormula a spray:CalculationFormula,
        owl:NamedIndividual ;
    rdfs:label "availability_pct 公式"@zh ;
    spray:fieldKey "availability_pct" ;
    spray:formulaExpression "available_time_sec / planned_time_sec * 100" ;
    spray:sourceStatus "TimeSeriesService0531_calculation_rule" .

