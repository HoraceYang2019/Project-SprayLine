@prefix mis: <http://nkust.edu.tw/mislab#> .
@prefix spray: <http://nkust.edu.tw/mislab/spray/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

mis:Signal_w0001_flow_ml_min a spray:FlowSignal ;
    spray:belongsToWindow mis:RuntimeWindow_w0001 ;
    spray:hasUnit "ml/min" ;
    spray:hasValue 1.8e+02 ;
    spray:mapsToJSONField spray:Field_flow .

mis:Signal_w0001_pressure_bar a spray:PressureSignal ;
    spray:belongsToWindow mis:RuntimeWindow_w0001 ;
    spray:hasUnit "bar" ;
