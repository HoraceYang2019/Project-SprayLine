mis:RuntimeWindow_w0001 a spray:SprayWindow ;
    mis:flowLossRatio 1.818182e-01 ;
    mis:pressureErrorRatio 8e-02 ;
    mis:sprayWidthErrorRatio 1.166667e-01 ;
    mis:thicknessErrorRatio 1.142857e-01 ;
    spray:hasBatchId "batch-A" ;
    spray:hasEndTime "2026-05-10T09:00:00.200000"^^xsd:dateTime ;
    spray:hasLineId "sprayline01" ;
    spray:hasSegmentId "seg-001" ;
    spray:hasStartTime "2026-05-10T09:00:00"^^xsd:dateTime ;
    spray:hasWindowId "w0001" ;
    spray:mapsToJSONField spray:Field_window ;
