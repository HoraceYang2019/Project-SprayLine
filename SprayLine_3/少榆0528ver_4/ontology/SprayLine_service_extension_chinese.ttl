    rdfs:domain spray:Entity ;
    rdfs:range xsd:string .

spray:displayedBy a owl:ObjectProperty ;
    rdfs:domain spray:DashboardSnapshot ;
    rdfs:range spray:InterfaceAsset .

spray:generatedAt a owl:DatatypeProperty ;
    rdfs:domain spray:RuntimeData ;
    rdfs:range xsd:string .

spray:generatedBy a owl:ObjectProperty ;
    rdfs:domain spray:RuntimeData ;
    rdfs:range spray:Service .

spray:hasAppliesToScope a owl:ObjectProperty ;
    rdfs:domain spray:ThresholdConfig ;
    rdfs:range spray:AppliesToScope .

spray:hasComponent a owl:ObjectProperty ;
    rdfs:domain spray:Station ;
    rdfs:range spray:Component .

spray:hasDownstreamInterface a owl:ObjectProperty ;
    rdfs:domain spray:Service ;
    rdfs:range spray:InterfaceAsset .

spray:hasDownstreamService a owl:ObjectProperty ;
    rdfs:domain spray:Service ;
    rdfs:range spray:Service .

spray:hasInput a owl:ObjectProperty ;
    rdfs:domain spray:Service ;
    rdfs:range spray:RuntimeData .

spray:hasInputParameter a owl:ObjectProperty ;
    rdfs:label "具有輸入參數"@zh ;
    rdfs:domain spray:Function ;
    rdfs:range spray:FunctionInputParameter .

spray:hasJSONField a owl:ObjectProperty ;
    rdfs:domain spray:FieldCatalog ;
    rdfs:range spray:JSONField .

spray:hasLineSummary a owl:ObjectProperty ;
    rdfs:domain spray:DashboardSnapshot ;
    rdfs:range spray:LineSummary .

spray:hasMetric a owl:ObjectProperty ;
    rdfs:domain spray:RuntimeData ;
    rdfs:range spray:Metric .

spray:hasOutput a owl:ObjectProperty ;
    rdfs:domain spray:Service ;
    rdfs:range spray:RuntimeData .

spray:hasOutputParameter a owl:ObjectProperty ;
    rdfs:label "具有輸出參數"@zh ;
    rdfs:domain spray:Function ;
    rdfs:range spray:FunctionOutputParameter .

spray:hasProcessParameter a owl:ObjectProperty ;
    rdfs:domain spray:RuntimeData ;
    rdfs:range spray:ProcessParameter .

spray:hasRiskAssessment a owl:ObjectProperty ;
    rdfs:domain spray:RuntimeData ;
    rdfs:range spray:RiskAssessment .

spray:hasSamplingMethod a owl:ObjectProperty ;
    rdfs:domain spray:Service ;
    rdfs:range spray:SamplingMethod .

spray:hasState a owl:ObjectProperty ;
    rdfs:domain spray:RuntimeData ;
    rdfs:range spray:StationState .

spray:hasStation a owl:ObjectProperty ;
    rdfs:domain spray:SprayLine ;
    rdfs:range spray:Station .

spray:hasStationSummary a owl:ObjectProperty ;
    rdfs:domain spray:DashboardSnapshot ;
    rdfs:range spray:StatisticsStationSummary .

spray:hasThresholdRule a owl:ObjectProperty ;
    rdfs:domain spray:ThresholdConfig ;
    rdfs:range spray:ThresholdRule .

spray:hasThresholdSourceType a owl:ObjectProperty ;
    rdfs:domain spray:ThresholdConfig ;
    rdfs:range spray:ThresholdSourceType .

spray:hasTrendSeries a owl:ObjectProperty ;
    rdfs:domain spray:DashboardSnapshot ;
    rdfs:range spray:TrendSeries .

spray:hasUpstreamCause a owl:ObjectProperty ;
    rdfs:label "具有上游原因"@zh ;
    rdfs:comment "此關係用於從下游結果回指上游原因，僅作解釋用途，不代表下游結果會反向影響上游元件。"@zh ;
    rdfs:domain spray:RuntimeData ;
    rdfs:range spray:Entity .

spray:hasUpstreamService a owl:ObjectProperty ;
    rdfs:domain spray:Service ;
    rdfs:range spray:Service .

spray:hasWindow a owl:ObjectProperty ;
    rdfs:domain spray:RuntimeData ;
    rdfs:range spray:StatisticsWindow .

spray:hasWindowPolicy a owl:ObjectProperty ;
    rdfs:domain spray:Service ;
    rdfs:range spray:WindowPolicy .

spray:lineId a owl:DatatypeProperty ;
    rdfs:label "產線編號"@zh ;
    rdfs:comment "與 Database function 對接的識別欄位使用 line_id；底漆、面漆、金漆等 station 概念仍可作為製程位置或 UI 顯示標籤。"@zh ;
    rdfs:domain spray:Entity,
        spray:Station ;
    rdfs:range xsd:string .

