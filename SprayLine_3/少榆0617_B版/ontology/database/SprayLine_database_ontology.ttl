@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix spray: <http://nkust.edu.tw/mislab/spraying/ontology#> .
spray:DatabaseOntology a owl:Ontology .
spray:DatabaseConcept a owl:Class ; rdfs:label "資料庫概念"@zh .
spray:DatabaseTable a owl:Class ; rdfs:label "資料表"@zh ; rdfs:subClassOf spray:DatabaseConcept .
spray:BatchDataTable a owl:Class ; rdfs:label "批次資料表"@zh ; rdfs:subClassOf spray:DatabaseTable .
spray:SensorDataTable a owl:Class ; rdfs:label "感測資料表"@zh ; rdfs:subClassOf spray:DatabaseTable .
spray:StateDataTable a owl:Class ; rdfs:label "狀態資料表"@zh ; rdfs:subClassOf spray:DatabaseTable .
spray:EventDataTable a owl:Class ; rdfs:label "事件資料表"@zh ; rdfs:subClassOf spray:DatabaseTable .
spray:KnowledgeDataTable a owl:Class ; rdfs:label "知識資料表"@zh ; rdfs:subClassOf spray:DatabaseTable .
spray:TroubleshootingDataTable a owl:Class ; rdfs:label "原因對策資料表"@zh ; rdfs:subClassOf spray:DatabaseTable .
spray:storesSignal a owl:ObjectProperty ; rdfs:label "儲存訊號"@zh ; rdfs:domain spray:DatabaseTable ; rdfs:range spray:SensorSignal .
spray:hasPersistenceStatus a owl:DatatypeProperty ; rdfs:label "持久化狀態"@zh ; rdfs:range xsd:string .
spray:batch_run a owl:Class, owl:NamedIndividual, spray:BatchDataTable ; rdfs:label "batch_run"@zh ; rdfs:subClassOf spray:BatchDataTable .
spray:sensor_1min a owl:Class, owl:NamedIndividual, spray:SensorDataTable ; rdfs:label "sensor_1min"@zh ; rdfs:subClassOf spray:SensorDataTable .
spray:sensor_3min a owl:Class, owl:NamedIndividual, spray:SensorDataTable ; rdfs:label "sensor_3min"@zh ; rdfs:subClassOf spray:SensorDataTable .
spray:batch_station_status a owl:Class, owl:NamedIndividual, spray:StateDataTable ; rdfs:label "batch_station_status"@zh ; rdfs:subClassOf spray:StateDataTable .
spray:alert_event a owl:Class, owl:NamedIndividual, spray:EventDataTable ; rdfs:label "alert_event"@zh ; rdfs:subClassOf spray:EventDataTable .
spray:alert_cause_link a owl:Class, owl:NamedIndividual, spray:EventDataTable ; rdfs:label "alert_cause_link"@zh ; rdfs:subClassOf spray:EventDataTable .
spray:alert_response_link a owl:Class, owl:NamedIndividual, spray:EventDataTable ; rdfs:label "alert_response_link"@zh ; rdfs:subClassOf spray:EventDataTable .
spray:cause_catalog a owl:Class, owl:NamedIndividual, spray:KnowledgeDataTable ; rdfs:label "cause_catalog"@zh ; rdfs:subClassOf spray:KnowledgeDataTable .
spray:response_catalog a owl:Class, owl:NamedIndividual, spray:KnowledgeDataTable ; rdfs:label "response_catalog"@zh ; rdfs:subClassOf spray:KnowledgeDataTable .
spray:component_catalog a owl:Class, owl:NamedIndividual, spray:TroubleshootingDataTable ; rdfs:label "component_catalog"@zh ; rdfs:subClassOf spray:TroubleshootingDataTable .
spray:issue_catalog a owl:Class, owl:NamedIndividual, spray:TroubleshootingDataTable ; rdfs:label "issue_catalog"@zh ; rdfs:subClassOf spray:TroubleshootingDataTable .
spray:solution_catalog a owl:Class, owl:NamedIndividual, spray:TroubleshootingDataTable ; rdfs:label "solution_catalog"@zh ; rdfs:subClassOf spray:TroubleshootingDataTable .
spray:component_issue_solution_map a owl:Class, owl:NamedIndividual, spray:TroubleshootingDataTable ; rdfs:label "component_issue_solution_map"@zh ; rdfs:subClassOf spray:TroubleshootingDataTable .
spray:sensor_1min spray:storesSignal spray:film_thickness_um, spray:paint_flow_ml_min, spray:nozzle_roll, spray:filter_diff_pressure_bar, spray:filter_inflow_ml_min, spray:filter_outflow_ml_min, spray:pump_current_a, spray:air_pressure_bar, spray:spray_width_mm, spray:servo_torque_load_pct, spray:path_error_mm, spray:vibration_g, spray:tcp_x_mm, spray:tcp_y_mm, spray:tcp_z_mm, spray:speed_mm_s .
spray:sensor_3min spray:storesSignal spray:gearbox_temperature_c, spray:temperature_c, spray:humidity_rh .
spray:data_quality_flag a owl:NamedIndividual, spray:DataQualityFlag ; rdfs:label "data_quality_flag"@zh ; spray:hasPersistenceStatus "not_persisted_in_schema_v5" .
