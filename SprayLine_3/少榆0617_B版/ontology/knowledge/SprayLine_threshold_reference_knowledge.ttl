@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix spray: <http://nkust.edu.tw/mislab/spraying/ontology#> .
spray:ThresholdReferenceKnowledge a owl:Ontology .
spray:thresholdId a owl:DatatypeProperty ; rdfs:label "thresholdId"@zh .
spray:sourceTable a owl:DatatypeProperty ; rdfs:label "sourceTable"@zh .
spray:stationScope a owl:DatatypeProperty ; rdfs:label "stationScope"@zh .
spray:normalExpression a owl:DatatypeProperty ; rdfs:label "normalExpression"@zh .
spray:warningExpression a owl:DatatypeProperty ; rdfs:label "warningExpression"@zh .
spray:faultExpression a owl:DatatypeProperty ; rdfs:label "faultExpression"@zh .
spray:thresholdUnit a owl:DatatypeProperty ; rdfs:label "thresholdUnit"@zh .
spray:thresholdSource a owl:DatatypeProperty ; rdfs:label "thresholdSource"@zh .
spray:thresholdStatus a owl:DatatypeProperty ; rdfs:label "thresholdStatus"@zh .
spray:appliesToSignal a owl:ObjectProperty ; rdfs:label "適用訊號"@zh ; rdfs:domain spray:SensorThresholdReference ; rdfs:range spray:SensorSignal .
spray:TH_FILTER_DIFF_ALL a owl:NamedIndividual, spray:SensorThresholdReference ; rdfs:label "filter_diff_pressure_bar 門檻參考"@zh ; spray:thresholdId "TH_FILTER_DIFF_ALL" ; spray:appliesToSignal spray:filter_diff_pressure_bar ; spray:sourceTable "sensor_1min" ; spray:stationScope "ALL" ; spray:normalExpression "0.1 <= value <= 0.5" ; spray:warningExpression "0.5 < value <= 0.7" ; spray:faultExpression "value > 0.7" ; spray:thresholdUnit "bar" ; spray:thresholdSource "DataPreprocess_spray0609" ; spray:thresholdStatus "reference_active" .
spray:TH_SERVO_TORQUE_ALL a owl:NamedIndividual, spray:SensorThresholdReference ; rdfs:label "servo_torque_load_pct 門檻參考"@zh ; spray:thresholdId "TH_SERVO_TORQUE_ALL" ; spray:appliesToSignal spray:servo_torque_load_pct ; spray:sourceTable "sensor_1min" ; spray:stationScope "ALL" ; spray:normalExpression "40.0 <= value <= 60.0" ; spray:warningExpression "60.0 < value <= 75.0" ; spray:faultExpression "value > 75.0" ; spray:thresholdUnit "%" ; spray:thresholdSource "DataPreprocess_spray0609" ; spray:thresholdStatus "reference_active" .
spray:TH_AIR_PRESSURE_ALL a owl:NamedIndividual, spray:SensorThresholdReference ; rdfs:label "air_pressure_bar 門檻參考"@zh ; spray:thresholdId "TH_AIR_PRESSURE_ALL" ; spray:appliesToSignal spray:air_pressure_bar ; spray:sourceTable "sensor_1min" ; spray:stationScope "ALL" ; spray:normalExpression "2.4 <= value <= 2.6" ; spray:warningExpression "2.3 <= value < 2.4 OR 2.6 < value <= 2.7" ; spray:faultExpression "value < 2.3 OR value > 2.7" ; spray:thresholdUnit "bar" ; spray:thresholdSource "DataPreprocess_spray0609" ; spray:thresholdStatus "reference_active" .
spray:TH_TEMPERATURE_ALL a owl:NamedIndividual, spray:SensorThresholdReference ; rdfs:label "temperature_c 門檻參考"@zh ; spray:thresholdId "TH_TEMPERATURE_ALL" ; spray:appliesToSignal spray:temperature_c ; spray:sourceTable "sensor_3min" ; spray:stationScope "ALL" ; spray:normalExpression "20.0 <= value <= 30.0" ; spray:warningExpression "15.0 <= value < 20.0 OR 30.0 < value <= 35.0" ; spray:faultExpression "value < 15.0 OR value > 35.0" ; spray:thresholdUnit "degC" ; spray:thresholdSource "DataPreprocess_spray0609" ; spray:thresholdStatus "reference_active" .
spray:TH_HUMIDITY_ALL a owl:NamedIndividual, spray:SensorThresholdReference ; rdfs:label "humidity_rh 門檻參考"@zh ; spray:thresholdId "TH_HUMIDITY_ALL" ; spray:appliesToSignal spray:humidity_rh ; spray:sourceTable "sensor_3min" ; spray:stationScope "ALL" ; spray:normalExpression "45.0 <= value <= 65.0" ; spray:warningExpression "35.0 <= value < 45.0 OR 65.0 < value <= 75.0" ; spray:faultExpression "value < 35.0 OR value > 75.0" ; spray:thresholdUnit "%RH" ; spray:thresholdSource "DataPreprocess_spray0609" ; spray:thresholdStatus "reference_active" .
spray:TH_PAINT_FLOW_ALL a owl:NamedIndividual, spray:SensorThresholdReference ; rdfs:label "paint_flow_ml_min 門檻參考"@zh ; spray:thresholdId "TH_PAINT_FLOW_ALL" ; spray:appliesToSignal spray:paint_flow_ml_min ; spray:sourceTable "sensor_1min" ; spray:stationScope "ALL" ; spray:normalExpression "105.0 <= value <= 125.0" ; spray:warningExpression "95.0 <= value < 105.0" ; spray:faultExpression "value < 95.0 OR value > 125.0" ; spray:thresholdUnit "ml/min" ; spray:thresholdSource "DataPreprocess_spray0609" ; spray:thresholdStatus "reference_active" .
spray:TH_SPRAY_WIDTH_ALL a owl:NamedIndividual, spray:SensorThresholdReference ; rdfs:label "spray_width_mm 門檻參考"@zh ; spray:thresholdId "TH_SPRAY_WIDTH_ALL" ; spray:appliesToSignal spray:spray_width_mm ; spray:sourceTable "sensor_1min" ; spray:stationScope "ALL" ; spray:normalExpression "105.0 <= value <= 125.0" ; spray:warningExpression "95.0 <= value < 105.0" ; spray:faultExpression "value < 95.0 OR value > 125.0" ; spray:thresholdUnit "mm" ; spray:thresholdSource "DataPreprocess_spray0609" ; spray:thresholdStatus "reference_active" .
spray:TH_PATH_ERROR_ALL a owl:NamedIndividual, spray:SensorThresholdReference ; rdfs:label "path_error_mm 門檻參考"@zh ; spray:thresholdId "TH_PATH_ERROR_ALL" ; spray:appliesToSignal spray:path_error_mm ; spray:sourceTable "sensor_1min" ; spray:stationScope "ALL" ; spray:normalExpression "0.00 <= value <= 0.10" ; spray:warningExpression "0.10 < value <= 0.15" ; spray:faultExpression "value > 0.15" ; spray:thresholdUnit "mm" ; spray:thresholdSource "DataPreprocess_spray0609" ; spray:thresholdStatus "reference_active" .
