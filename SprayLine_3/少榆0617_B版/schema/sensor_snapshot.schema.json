{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Latest sensor snapshot",
  "type": "object",
  "properties": {
    "station": {
      "type": "string"
    },
    "sensor_1min": {
      "anyOf": [
        {
          "$ref": "sensor_1min.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "sensor_3min": {
      "anyOf": [
        {
          "$ref": "sensor_3min.schema.json"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "station"
  ],
  "additionalProperties": false
}
