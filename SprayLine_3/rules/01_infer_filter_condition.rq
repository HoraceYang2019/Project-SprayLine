PREFIX spray: <http://nkust.edu.tw/mislab/spray/ontology#>
PREFIX mis: <http://nkust.edu.tw/mislab#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

CONSTRUCT {
  ?window spray:indicatesFilterCondition ?state .
  ?diag spray:diagnosesWindow ?window ;
        spray:indicatesFilterCondition ?state ;
        spray:hasConfidence ?conf ;
        spray:hasStateLabel ?label .
}
WHERE {
  ?window rdf:type spray:SprayWindow ;
          spray:hasWindowId ?wid ;
          mis:flowLossRatio ?flowLoss .
  ?state rdf:type mis:BatchKnowledge ;
         mis:hasKnowledgeCategory "filter_condition" ;
         mis:minFlowLossRatio ?min ;
         mis:maxFlowLossRatio ?max ;
         mis:confidence ?conf .
  FILTER(?flowLoss >= ?min && ?flowLoss < ?max)
  BIND(IRI(CONCAT(STR(mis:), "Diagnosis_", STR(?wid), "_filter")) AS ?diag)
  BIND(STRAFTER(STR(?state), STR(mis:)) AS ?label)
}
