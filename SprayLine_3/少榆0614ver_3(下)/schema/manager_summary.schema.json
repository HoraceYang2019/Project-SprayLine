{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Manager summary",
  "type": "object",
  "properties": {
    "date": {
      "type": "string"
    },
    "station": {
      "type": [
        "string",
        "null"
      ]
    },
    "total_batches": {
      "type": "integer"
    },
    "ok_batches": {
      "type": "integer"
    },
    "warning_batches": {
      "type": "integer"
    },
    "bad_batches": {
      "type": "integer"
    },
    "total_alerts": {
      "type": "integer"
    },
    "unacknowledged_alerts": {
      "type": "integer"
    },
    "station_breakdown": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "future_prediction_summary": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "available": {
          "type": "boolean"
        },
        "pending_db_table": {
          "type": "boolean"
        },
        "latest_risk_level": {
          "type": [
            "string",
            "null"
          ]
        },
        "latest_predicted_ok_rate": {
          "type": [
            "number",
            "null"
          ]
        },
        "latest_predicted_ng_count": {
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "required": [
    "date",
    "total_batches",
    "station_breakdown"
  ],
  "additionalProperties": true
}
