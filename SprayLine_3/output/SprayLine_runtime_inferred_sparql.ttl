mis:Diagnosis_w0001_filter spray:diagnosesWindow mis:RuntimeWindow_w0001 ;
    spray:hasConfidence 9.4e-01 ;
    spray:hasStateLabel "FilterModerateBlock" ;
    spray:indicatesFilterCondition mis:FilterModerateBlock .

