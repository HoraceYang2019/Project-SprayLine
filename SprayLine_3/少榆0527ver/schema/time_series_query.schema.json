{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/spray-line/time-series-query.contract.schema.json",
  "title": "Time Series Query Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "mode",
    "window_type",
    "slider_value",
    "station_scope",
    "return_to_now"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "request_id": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "description": "UI 查詢模式"
    },
    "window_type": {
      "type": "string",
      "description": "統計視窗類型"
    },
    "slider_value": {
      "type": "number",
      "description": "UI slider 位置"
    },
    "station_scope": {
      "type": [
        "string",
        "array"
      ],
      "description": "查詢站別範圍"
    },
    "return_to_now": {
      "type": "boolean"
    },
    "requested_metrics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$comment": "檔案備註：Time Series Viewer 查詢 schema：驗證前端拖動時間軸或切換模式時送進 service 的查詢欄位。；資料夾流程定位：流程 Step 3：建立 API contract 與 JSON Schema，只驗證結構與型別，不綁定數值。"
}
