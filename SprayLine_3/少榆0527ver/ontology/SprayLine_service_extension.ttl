@prefix : <http://nkust.edu.tw/mislab/spraying/ontology#> .
@prefix spray: <http://nkust.edu.tw/mislab/spraying/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://nkust.edu.tw/mislab/spraying/ontology>
 rdf:type owl:Ontology ;
 rdfs:label "Spraying Line Service Ontology v3"@en ;
 owl:versionInfo "v3 English-only corrected hierarchy and instance version" ;
 rdfs:comment "English-only ontology aligned with the unenhanced Past/Current Service and Statistics Service. This version improves the class hierarchy, separates service nodes from interface nodes, adds named individuals for OntoGraf visualization, and keeps unresolved window/sample/unit issues as policy individuals instead of hard-coded service rules."@en .

#################################################################
# 1. Core class hierarchy
#################################################################

:Entity rdf:type owl:Class ;
 rdfs:label "Entity"@en .

:PhysicalAsset rdf:type owl:Class ;
 rdfs:subClassOf :Entity ;
 rdfs:label "Physical Asset"@en .

:CyberAsset rdf:type owl:Class ;
 rdfs:subClassOf :Entity ;
 rdfs:label "Cyber Asset"@en .

:KnowledgeAsset rdf:type owl:Class ;
 rdfs:subClassOf :CyberAsset ;
 rdfs:label "Knowledge Asset"@en .

:RuntimeData rdf:type owl:Class ;
 rdfs:subClassOf :CyberAsset ;
 rdfs:label "Runtime Data"@en .

:Service rdf:type owl:Class ;
 rdfs:subClassOf :CyberAsset ;
 rdfs:label "Service"@en .

:InterfaceAsset rdf:type owl:Class ;
 rdfs:subClassOf :CyberAsset ;
 rdfs:label "Interface Asset"@en .

:DataContractArtifact rdf:type owl:Class ;
 rdfs:subClassOf :CyberAsset ;
 rdfs:label "Data Contract Artifact"@en .

#################################################################
# 2. Physical asset hierarchy
#################################################################

:SprayLine rdf:type owl:Class ;
 rdfs:subClassOf :PhysicalAsset ;
 rdfs:label "Spray Line"@en .

:Chamber rdf:type owl:Class ;
 rdfs:subClassOf :PhysicalAsset ;
 rdfs:label "Chamber"@en .

:Station rdf:type owl:Class ;
 rdfs:subClassOf :PhysicalAsset ;
 rdfs:label "Station"@en .

:PrimerStation rdf:type owl:Class ;
 rdfs:subClassOf :Station ;
 rdfs:label "Primer Station"@en .

:TopcoatStation rdf:type owl:Class ;
 rdfs:subClassOf :Station ;
 rdfs:label "Topcoat Station"@en .

:GoldPaintStation rdf:type owl:Class ;
 rdfs:subClassOf :Station ;
 rdfs:label "Gold Paint Station"@en .

:Component rdf:type owl:Class ;
 rdfs:subClassOf :PhysicalAsset ;
 rdfs:label "Component"@en .

:RobotArm rdf:type owl:Class ;
 rdfs:subClassOf :Component ;
 rdfs:label "Robot Arm"@en .

:Nozzle rdf:type owl:Class ;
 rdfs:subClassOf :Component ;
 rdfs:label "Nozzle"@en .

:AirCompressor rdf:type owl:Class ;
 rdfs:subClassOf :Component ;
 rdfs:label "AirCompressor"@en .

:AirValve rdf:type owl:Class ;
 rdfs:subClassOf :Component ;
 rdfs:label "Air Valve"@en .

:FilterMesh rdf:type owl:Class ;
 rdfs:subClassOf :Component ;
 rdfs:label "Filter Mesh"@en .

:QualityModule rdf:type owl:Class ;
 rdfs:subClassOf :Component ;
 rdfs:label "Quality Module"@en .

:Controller rdf:type owl:Class ;
 rdfs:subClassOf :Component ;
 rdfs:label "Controller"@en .

:Sensor rdf:type owl:Class ;
 rdfs:subClassOf :Component ;
 rdfs:label "Sensor"@en .

#################################################################
# 3. Service hierarchy
#################################################################

:PastService rdf:type owl:Class ;
 rdfs:subClassOf :Service ;
 rdfs:label "Past Service"@en ;
 rdfs:comment "Provides historical station snapshots."@en .

:CurrentService rdf:type owl:Class ;
 rdfs:subClassOf :Service ;
 rdfs:label "Current Service"@en ;
 rdfs:comment "Provides current or near-real-time station snapshots."@en .

:FutureService rdf:type owl:Class ;
 rdfs:subClassOf :Service ;
 rdfs:label "Future Service"@en ;
 rdfs:comment "Produces future station predictions from past and current snapshots."@en .

:StatisticsService rdf:type owl:Class ;
 rdfs:subClassOf :Service ;
 rdfs:label "Statistics Service"@en ;
 rdfs:comment "Aggregates past, current, and future data into dashboard and time-series outputs."@en .

:RuleService rdf:type owl:Class ;
 rdfs:subClassOf :Service ;
 rdfs:label "Rule Service"@en .

:OntologyService rdf:type owl:Class ;
 rdfs:subClassOf :Service ;
 rdfs:label "Ontology Service"@en .

:RuntimeTTLGenerator rdf:type owl:Class ;
 rdfs:subClassOf :Service ;
 rdfs:label "Runtime TTL Generator"@en .

:UIService rdf:type owl:Class ;
 rdfs:subClassOf :Service ;
 rdfs:label "UI Service"@en .

:EngineeringDashboard rdf:type owl:Class ;
 rdfs:subClassOf :InterfaceAsset ;
 rdfs:label "Engineering Dashboard"@en ;
 rdfs:comment "UI(E), the engineer-facing dashboard."@en .

#################################################################
# 4. Window hierarchy
#################################################################

:StatisticsWindow rdf:type owl:Class ;
 rdfs:subClassOf :RuntimeData ;
 rdfs:label "Statistics Window"@en ;
 rdfs:comment "Unified window concept for past, current, future, and statistics services."@en .

:HistoricalWindow rdf:type owl:Class ;
 rdfs:subClassOf :StatisticsWindow ;
 rdfs:label "Historical Window"@en .

:CurrentWindow rdf:type owl:Class ;
 rdfs:subClassOf :StatisticsWindow ;
 rdfs:label "Current Window"@en .

:PredictionWindow rdf:type owl:Class ;
 rdfs:subClassOf :StatisticsWindow ;
 rdfs:label "Prediction Window"@en .

:TimeWindow rdf:type owl:Class ;
 rdfs:subClassOf :StatisticsWindow ;
 rdfs:label "Time Window"@en .

:BatchWindow rdf:type owl:Class ;
 rdfs:subClassOf :StatisticsWindow ;
 rdfs:label "Batch Window"@en .

:TwoHourWindow rdf:type owl:Class ;
 rdfs:subClassOf :HistoricalWindow, :TimeWindow ;
 rdfs:label "Two Hour Window"@en .

:TenBatchWindow rdf:type owl:Class ;
 rdfs:subClassOf :HistoricalWindow, :BatchWindow ;
 rdfs:label "Ten Batch Window"@en .

:CurrentDefinedBySystemWindow rdf:type owl:Class ;
 rdfs:subClassOf :CurrentWindow ;
 rdfs:label "Current Window Defined by System"@en .

#################################################################
# 5. Runtime data hierarchy
#################################################################

:StationSnapshot rdf:type owl:Class ;
 rdfs:subClassOf :RuntimeData ;
 rdfs:label "Station Snapshot"@en .

:PastStationSnapshot rdf:type owl:Class ;
 rdfs:subClassOf :StationSnapshot ;
 rdfs:label "Past Station Snapshot"@en .

:CurrentStationSnapshot rdf:type owl:Class ;
 rdfs:subClassOf :StationSnapshot ;
 rdfs:label "Current Station Snapshot"@en .

:FutureStationPrediction rdf:type owl:Class ;
 rdfs:subClassOf :RuntimeData ;
 rdfs:label "Future Station Prediction"@en .

:StatisticsStationSummary rdf:type owl:Class ;
 rdfs:subClassOf :RuntimeData ;
 rdfs:label "Statistics Station Summary"@en .

:DashboardSnapshot rdf:type owl:Class ;
 rdfs:subClassOf :RuntimeData ;
 rdfs:label "Dashboard Snapshot"@en .

:LineSummary rdf:type owl:Class ;
 rdfs:subClassOf :RuntimeData ;
 rdfs:label "Line Summary"@en .

:TrendSeries rdf:type owl:Class ;
 rdfs:subClassOf :RuntimeData ;
 rdfs:label "Trend Series"@en .

:TimeSeriesViewerOutput rdf:type owl:Class ;
 rdfs:subClassOf :RuntimeData ;
 rdfs:label "Time Series Viewer Output"@en .

#################################################################
# 6. Metric and process parameter hierarchy
#################################################################

:Metric rdf:type owl:Class ;
 rdfs:subClassOf :RuntimeData ;
 rdfs:label "Metric"@en .

:PressureMetric rdf:type owl:Class ;
 rdfs:subClassOf :Metric ;
 rdfs:label "Pressure Metric"@en .

:FlowRateMetric rdf:type owl:Class ;
 rdfs:subClassOf :Metric ;
 rdfs:label "Flow Rate Metric"@en .

:QualityMetric rdf:type owl:Class ;
 rdfs:subClassOf :Metric ;
 rdfs:label "Quality Metric"@en .

:AvailabilityMetric rdf:type owl:Class ;
 rdfs:subClassOf :Metric ;
 rdfs:label "Availability Metric"@en .

:ClogRateMetric rdf:type owl:Class ;
 rdfs:subClassOf :Metric ;
 rdfs:label "Clog Rate Metric"@en .

:MaintainabilityMetric rdf:type owl:Class ;
 rdfs:subClassOf :Metric ;
 rdfs:label "Maintainability Metric"@en .

:ProcessParameter rdf:type owl:Class ;
 rdfs:subClassOf :RuntimeData ;
 rdfs:label "Process Parameter"@en .

:TemperatureParameter rdf:type owl:Class ;
 rdfs:subClassOf :ProcessParameter ;
 rdfs:label "Temperature Parameter"@en .

:UtilizationParameter rdf:type owl:Class ;
 rdfs:subClassOf :ProcessParameter ;
 rdfs:label "Utilization Parameter"@en .

:CycleTimeParameter rdf:type owl:Class ;
 rdfs:subClassOf :ProcessParameter ;
 rdfs:label "Cycle Time Parameter"@en .

#################################################################
# 7. State, risk, and policy hierarchy
#################################################################

:StationState rdf:type owl:Class ;
 rdfs:subClassOf :RuntimeData ;
 rdfs:label "Station State"@en .

:RiskAssessment rdf:type owl:Class ;
 rdfs:subClassOf :RuntimeData ;
 rdfs:label "Risk Assessment"@en .

:SamplingMethod rdf:type owl:Class ;
 rdfs:subClassOf :KnowledgeAsset ;
 rdfs:label "Sampling Method"@en .

:WindowPolicy rdf:type owl:Class ;
 rdfs:subClassOf :KnowledgeAsset ;
 rdfs:label "Window Policy"@en .

:ThresholdConfig rdf:type owl:Class ;
 rdfs:subClassOf :KnowledgeAsset ;
 rdfs:label "Threshold Config"@en .

#################################################################
# 8. Data contract hierarchy
#################################################################

:SchemaArtifact rdf:type owl:Class ;
 rdfs:subClassOf :DataContractArtifact ;
 rdfs:label "Schema Artifact"@en .

:TemplateArtifact rdf:type owl:Class ;
 rdfs:subClassOf :DataContractArtifact ;
 rdfs:label "Template Artifact"@en .

:FieldCatalog rdf:type owl:Class ;
 rdfs:subClassOf :DataContractArtifact ;
 rdfs:label "Field Catalog"@en .

:JSONField rdf:type owl:Class ;
 rdfs:subClassOf :DataContractArtifact ;
 rdfs:label "JSON Field"@en .

:RuntimeTTLArtifact rdf:type owl:Class ;
 rdfs:subClassOf :DataContractArtifact ;
 rdfs:label "Runtime TTL Artifact"@en .

#################################################################
# 9. Object properties
#################################################################

:hasStation rdf:type owl:ObjectProperty ;
 rdfs:domain :SprayLine ;
 rdfs:range :Station ;
 rdfs:label "has station"@en .

:stationInChamber rdf:type owl:ObjectProperty ;
 rdfs:domain :Station ;
 rdfs:range :Chamber ;
 rdfs:label "station in chamber"@en .

:hasComponent rdf:type owl:ObjectProperty ;
 rdfs:domain :Station ;
 rdfs:range :Component ;
 rdfs:label "has component"@en .

:produces rdf:type owl:ObjectProperty ;
 rdfs:domain :Service ;
 rdfs:range :RuntimeData ;
 rdfs:label "produces"@en .

:generatedBy rdf:type owl:ObjectProperty ;
 rdfs:domain :RuntimeData ;
 rdfs:range :Service ;
 rdfs:label "generated by"@en .

:describesStation rdf:type owl:ObjectProperty ;
 rdfs:domain :RuntimeData ;
 rdfs:range :Station ;
 rdfs:label "describes station"@en .

:hasWindow rdf:type owl:ObjectProperty ;
 rdfs:domain :RuntimeData ;
 rdfs:range :StatisticsWindow ;
 rdfs:label "has window"@en .

:hasState rdf:type owl:ObjectProperty ;
 rdfs:domain :RuntimeData ;
 rdfs:range :StationState ;
 rdfs:label "has state"@en .

:hasMetric rdf:type owl:ObjectProperty ;
 rdfs:domain :RuntimeData ;
 rdfs:range :Metric ;
 rdfs:label "has metric"@en .

:hasProcessParameter rdf:type owl:ObjectProperty ;
 rdfs:domain :RuntimeData ;
 rdfs:range :ProcessParameter ;
 rdfs:label "has process parameter"@en .

:hasRiskAssessment rdf:type owl:ObjectProperty ;
 rdfs:domain :RuntimeData ;
 rdfs:range :RiskAssessment ;
 rdfs:label "has risk assessment"@en .

:usesPastSnapshot rdf:type owl:ObjectProperty ;
 rdfs:domain :FutureService ;
 rdfs:range :PastStationSnapshot ;
 rdfs:label "uses past snapshot"@en .

:usesCurrentSnapshot rdf:type owl:ObjectProperty ;
 rdfs:domain :FutureService ;
 rdfs:range :CurrentStationSnapshot ;
 rdfs:label "uses current snapshot"@en .

:aggregatesPastSnapshot rdf:type owl:ObjectProperty ;
 rdfs:domain :StatisticsService ;
 rdfs:range :PastStationSnapshot ;
 rdfs:label "aggregates past snapshot"@en .

:aggregatesCurrentSnapshot rdf:type owl:ObjectProperty ;
 rdfs:domain :StatisticsService ;
 rdfs:range :CurrentStationSnapshot ;
 rdfs:label "aggregates current snapshot"@en .

:usesFuturePrediction rdf:type owl:ObjectProperty ;
 rdfs:domain :StatisticsService ;
 rdfs:range :FutureStationPrediction ;
 rdfs:label "uses future prediction"@en .

:hasLineSummary rdf:type owl:ObjectProperty ;
 rdfs:domain :DashboardSnapshot ;
 rdfs:range :LineSummary ;
 rdfs:label "has line summary"@en .

:hasStationSummary rdf:type owl:ObjectProperty ;
 rdfs:domain :DashboardSnapshot ;
 rdfs:range :StatisticsStationSummary ;
 rdfs:label "has station summary"@en .

:hasTrendSeries rdf:type owl:ObjectProperty ;
 rdfs:domain :DashboardSnapshot ;
 rdfs:range :TrendSeries ;
 rdfs:label "has trend series"@en .

:displayedBy rdf:type owl:ObjectProperty ;
 rdfs:domain :DashboardSnapshot ;
 rdfs:range :InterfaceAsset ;
 rdfs:label "displayed by"@en .

:usesInterface rdf:type owl:ObjectProperty ;
 rdfs:domain :UIService ;
 rdfs:range :InterfaceAsset ;
 rdfs:label "uses interface"@en .

:hasInput rdf:type owl:ObjectProperty ;
 rdfs:domain :Service ;
 rdfs:range :RuntimeData ;
 rdfs:label "has input"@en .

:hasOutput rdf:type owl:ObjectProperty ;
 rdfs:domain :Service ;
 rdfs:range :RuntimeData ;
 rdfs:label "has output"@en .

:hasUpstreamService rdf:type owl:ObjectProperty ;
 rdfs:domain :Service ;
 rdfs:range :Service ;
 rdfs:label "has upstream service"@en .

:hasDownstreamService rdf:type owl:ObjectProperty ;
 rdfs:domain :Service ;
 rdfs:range :Service ;
 rdfs:label "has downstream service"@en .

:hasDownstreamInterface rdf:type owl:ObjectProperty ;
 rdfs:domain :Service ;
 rdfs:range :InterfaceAsset ;
 rdfs:label "has downstream interface"@en .

:validatesAgainst rdf:type owl:ObjectProperty ;
 rdfs:domain :TemplateArtifact ;
 rdfs:range :SchemaArtifact ;
 rdfs:label "validates against"@en .

:alignedWithOntology rdf:type owl:ObjectProperty ;
 rdfs:domain :DataContractArtifact ;
 rdfs:range :OntologyService ;
 rdfs:label "aligned with ontology"@en .

:convertedToRuntimeTTL rdf:type owl:ObjectProperty ;
 rdfs:domain :RuntimeData ;
 rdfs:range :RuntimeTTLArtifact ;
 rdfs:label "converted to runtime TTL"@en .

:hasJSONField rdf:type owl:ObjectProperty ;
 rdfs:domain :FieldCatalog ;
 rdfs:range :JSONField ;
 rdfs:label "has JSON field"@en .

:hasSamplingMethod rdf:type owl:ObjectProperty ;
 rdfs:domain :Service ;
 rdfs:range :SamplingMethod ;
 rdfs:label "has sampling method"@en .

:hasWindowPolicy rdf:type owl:ObjectProperty ;
 rdfs:domain :Service ;
 rdfs:range :WindowPolicy ;
 rdfs:label "has window policy"@en .

#################################################################
# 10. Data properties
#################################################################

:lineId rdf:type owl:DatatypeProperty ;
 rdfs:domain :Station ;
 rdfs:range xsd:string ;
 rdfs:label "station id"@en .

:stationNameZh rdf:type owl:DatatypeProperty ;
 rdfs:domain :Station ;
 rdfs:range xsd:string ;
 rdfs:label "station Chinese name"@en .

:stationNameEn rdf:type owl:DatatypeProperty ;
 rdfs:domain :Station ;
 rdfs:range xsd:string ;
 rdfs:label "station English name"@en .

:serviceName rdf:type owl:DatatypeProperty ;
 rdfs:domain :Service ;
 rdfs:range xsd:string ;
 rdfs:label "service name"@en .

:schemaVersion rdf:type owl:DatatypeProperty ;
 rdfs:domain :RuntimeData ;
 rdfs:range xsd:string ;
 rdfs:label "schema version"@en .

:generatedAt rdf:type owl:DatatypeProperty ;
 rdfs:domain :RuntimeData ;
 rdfs:range xsd:string ;
 rdfs:label "generated at"@en .

:windowId rdf:type owl:DatatypeProperty ;
 rdfs:domain :StatisticsWindow ;
 rdfs:range xsd:string ;
 rdfs:label "window id"@en .

:windowMode rdf:type owl:DatatypeProperty ;
 rdfs:domain :StatisticsWindow ;
 rdfs:range xsd:string ;
 rdfs:label "window mode"@en .

:windowType rdf:type owl:DatatypeProperty ;
 rdfs:domain :StatisticsWindow ;
 rdfs:range xsd:string ;
 rdfs:label "window type"@en .

:windowSize rdf:type owl:DatatypeProperty ;
 rdfs:domain :StatisticsWindow ;
 rdfs:range xsd:string ;
 rdfs:label "window size"@en .

:windowStart rdf:type owl:DatatypeProperty ;
 rdfs:domain :HistoricalWindow ;
 rdfs:range xsd:string ;
 rdfs:label "window start"@en .

:windowEnd rdf:type owl:DatatypeProperty ;
 rdfs:domain :HistoricalWindow ;
 rdfs:range xsd:string ;
 rdfs:label "window end"@en .

:displayLabel rdf:type owl:DatatypeProperty ;
 rdfs:domain :Entity ;
 rdfs:range xsd:string ;
 rdfs:label "display label"@en .

:metricValue rdf:type owl:DatatypeProperty ;
 rdfs:domain :Metric ;
 rdfs:range xsd:string ;
 rdfs:label "metric value"@en .

:metricUnit rdf:type owl:DatatypeProperty ;
 rdfs:domain :Metric ;
 rdfs:range xsd:string ;
 rdfs:label "metric unit"@en .

:parameterValue rdf:type owl:DatatypeProperty ;
 rdfs:domain :ProcessParameter ;
 rdfs:range xsd:string ;
 rdfs:label "parameter value"@en .

:parameterUnit rdf:type owl:DatatypeProperty ;
 rdfs:domain :ProcessParameter ;
 rdfs:range xsd:string ;
 rdfs:label "parameter unit"@en .

:riskText rdf:type owl:DatatypeProperty ;
 rdfs:domain :RiskAssessment ;
 rdfs:range xsd:string ;
 rdfs:label "risk text"@en .

:stateText rdf:type owl:DatatypeProperty ;
 rdfs:domain :StationState ;
 rdfs:range xsd:string ;
 rdfs:label "state text"@en .

#################################################################
# 11. Named individuals - physical line and stations
#################################################################

:SprayLine01 rdf:type owl:NamedIndividual, :SprayLine ;
 rdfs:label "SprayLine_01"@en ;
 :hasStation :M1, :M2, :M3 .

:Chamber1 rdf:type owl:NamedIndividual, :Chamber ;
 rdfs:label "Chamber_1"@en .

:Chamber2 rdf:type owl:NamedIndividual, :Chamber ;
 rdfs:label "Chamber_2"@en .

:Chamber3 rdf:type owl:NamedIndividual, :Chamber ;
 rdfs:label "Chamber_3"@en .

:M1 rdf:type owl:NamedIndividual, :PrimerStation ;
 :lineId "M1" ;
 :stationNameZh "底漆站" ;
 :stationNameEn "Primer Station" ;
 rdfs:label "M1 Primer Station"@en ;
 :stationInChamber :Chamber1 ;
 :hasComponent :LineM1RobotArm, :LineM1Nozzle, :LineM1AirCompressor, :LineM1AirValve, :LineM1FilterMesh, :LineM1QualityModule .

:M2 rdf:type owl:NamedIndividual, :TopcoatStation ;
 :lineId "M2" ;
 :stationNameZh "面漆站" ;
 :stationNameEn "Topcoat Station" ;
 rdfs:label "M2 Topcoat Station"@en ;
 :stationInChamber :Chamber2 ;
 :hasComponent :LineM2RobotArm, :LineM2Nozzle, :LineM2AirCompressor, :LineM2AirValve, :LineM2FilterMesh, :LineM2QualityModule .

:M3 rdf:type owl:NamedIndividual, :GoldPaintStation ;
 :lineId "M3" ;
 :stationNameZh "金漆站" ;
 :stationNameEn "Gold Paint Station" ;
 rdfs:label "M3 Gold Paint Station"@en ;
 :stationInChamber :Chamber3 ;
 :hasComponent :LineM3RobotArm, :LineM3Nozzle, :LineM3AirCompressor, :LineM3AirValve, :LineM3FilterMesh, :LineM3QualityModule .

:LineM1RobotArm rdf:type owl:NamedIndividual, :RobotArm ; rdfs:label "M1 Robot Arm"@en .
:LineM1Nozzle rdf:type owl:NamedIndividual, :Nozzle ; rdfs:label "M1 Nozzle"@en .
:LineM1AirCompressor rdf:type owl:NamedIndividual, :AirCompressor ; rdfs:label "M1 AirCompressor"@en .
:LineM1AirValve rdf:type owl:NamedIndividual, :AirValve ; rdfs:label "M1 Air Valve"@en .
:LineM1FilterMesh rdf:type owl:NamedIndividual, :FilterMesh ; rdfs:label "M1 Filter Mesh"@en .
:LineM1QualityModule rdf:type owl:NamedIndividual, :QualityModule ; rdfs:label "M1 Quality Module"@en .

:LineM2RobotArm rdf:type owl:NamedIndividual, :RobotArm ; rdfs:label "M2 Robot Arm"@en .
:LineM2Nozzle rdf:type owl:NamedIndividual, :Nozzle ; rdfs:label "M2 Nozzle"@en .
:LineM2AirCompressor rdf:type owl:NamedIndividual, :AirCompressor ; rdfs:label "M2 AirCompressor"@en .
:LineM2AirValve rdf:type owl:NamedIndividual, :AirValve ; rdfs:label "M2 Air Valve"@en .
:LineM2FilterMesh rdf:type owl:NamedIndividual, :FilterMesh ; rdfs:label "M2 Filter Mesh"@en .
:LineM2QualityModule rdf:type owl:NamedIndividual, :QualityModule ; rdfs:label "M2 Quality Module"@en .

:LineM3RobotArm rdf:type owl:NamedIndividual, :RobotArm ; rdfs:label "M3 Robot Arm"@en .
:LineM3Nozzle rdf:type owl:NamedIndividual, :Nozzle ; rdfs:label "M3 Nozzle"@en .
:LineM3AirCompressor rdf:type owl:NamedIndividual, :AirCompressor ; rdfs:label "M3 AirCompressor"@en .
:LineM3AirValve rdf:type owl:NamedIndividual, :AirValve ; rdfs:label "M3 Air Valve"@en .
:LineM3FilterMesh rdf:type owl:NamedIndividual, :FilterMesh ; rdfs:label "M3 Filter Mesh"@en .
:LineM3QualityModule rdf:type owl:NamedIndividual, :QualityModule ; rdfs:label "M3 Quality Module"@en .

#################################################################
# 12. Named individuals - states, windows, methods, policies
#################################################################

:Running rdf:type owl:NamedIndividual, :StationState ;
 :stateText "Running" ;
 rdfs:label "Running"@en .

:Standby rdf:type owl:NamedIndividual, :StationState ;
 :stateText "Standby" ;
 rdfs:label "Standby"@en .

:Stop rdf:type owl:NamedIndividual, :StationState ;
 :stateText "Stop" ;
 rdfs:label "Stop"@en .

:Maintenance rdf:type owl:NamedIndividual, :StationState ;
 :stateText "Maintenance" ;
 rdfs:label "Maintenance"@en .

:Alarm rdf:type owl:NamedIndividual, :StationState ;
 :stateText "Alarm" ;
 rdfs:label "Alarm"@en .

:HistoricalWindowW001 rdf:type owl:NamedIndividual, :HistoricalWindow ;
 :windowId "W001" ;
 :windowMode "time_or_batch" ;
 :windowType "2hour_or_10batch" ;
 :windowStart "to_be_defined" ;
 :windowEnd "to_be_defined" ;
 :displayLabel "past window" ;
 rdfs:label "HistoricalWindow_W001"@en .

:CurrentWindowW002 rdf:type owl:NamedIndividual, :CurrentDefinedBySystemWindow ;
 :windowId "W002" ;
 :windowMode "current" ;
 :windowType "current_window" ;
 :windowSize "defined_by_system" ;
 :displayLabel "current" ;
 rdfs:label "CurrentWindow_W002"@en .

:PredictionWindowW003 rdf:type owl:NamedIndividual, :PredictionWindow ;
 :windowId "W003" ;
 :windowMode "future" ;
 :windowType "prediction_window" ;
 :windowSize "defined_by_future_service" ;
 :displayLabel "future prediction window" ;
 rdfs:label "PredictionWindow_W003"@en .

:StatisticsWindowW004 rdf:type owl:NamedIndividual, :StatisticsWindow ;
 :windowId "W004" ;
 :windowMode "statistics" ;
 :windowType "dashboard_snapshot_window" ;
 :windowSize "follow_statistics_service_contract" ;
 :displayLabel "statistics dashboard window" ;
 rdfs:label "StatisticsWindow_W004"@en .

:PastSampleMethodDefinedByService rdf:type owl:NamedIndividual, :SamplingMethod ;
 rdfs:label "Past sample method defined by service"@en ;
 rdfs:comment "Pending: average, latest, max, min, median, or window summary."@en .

:CurrentSampleMethodDefinedByService rdf:type owl:NamedIndividual, :SamplingMethod ;
 rdfs:label "Current sample method defined by service"@en ;
 rdfs:comment "Pending: latest, latest valid, recent average, recent-N average, or short-window summary."@en .

:PastWindowPolicyInputDefined rdf:type owl:NamedIndividual, :WindowPolicy ;
 rdfs:label "Past window policy input defined"@en ;
 rdfs:comment "Past window may use 2hour or 10batch and should be clarified by service input."@en .

:CurrentWindowPolicyDefinedBySystem rdf:type owl:NamedIndividual, :WindowPolicy ;
