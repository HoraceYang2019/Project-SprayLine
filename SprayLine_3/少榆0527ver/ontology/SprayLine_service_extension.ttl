spray:hasWindowPolicy a owl:ObjectProperty ;
    rdfs:label "has window policy"@en ;
    rdfs:domain spray:Service ;
    rdfs:range spray:WindowPolicy .

spray:lineId a owl:DatatypeProperty ;
    rdfs:label "line id"@en,
        "station id"@en,
        "產線編號"@zh ;
    rdfs:comment "The database-facing identifier uses line_id. Station labels may still describe process positions such as primer, topcoat, and gold paint."@en,
        "與 Database function 對接的識別欄位使用 line_id；底漆、面漆、金漆等 station 概念仍可作為製程位置或 UI 顯示標籤。"@zh ;
    rdfs:domain spray:Entity,
        spray:Station ;
    rdfs:range xsd:string .

