@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix spray: <http://nkust.edu.tw/mislab/spraying/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://nkust.edu.tw/mislab/spraying/ontology> a owl:Ontology ;
    rdfs:label "Spraying Line Service Ontology v3"@en ;
    rdfs:comment "English-only ontology aligned with the unenhanced Past/Current Service and Statistics Service. This version improves the class hierarchy, separates service nodes from interface nodes, adds named individuals for OntoGraf visualization, and keeps unresolved window/sample/unit issues as policy individuals instead of hard-coded service rules."@en ;
    owl:versionInfo "v3 English-only corrected hierarchy and instance version" .

spray:Alarm a spray:StationState,
        owl:NamedIndividual ;
    rdfs:label "Alarm"@en ;
    spray:stateText "Alarm" .

spray:AvailabilityMetric a owl:Class ;
    rdfs:label "Availability Metric"@en ;
    rdfs:subClassOf spray:Metric .

spray:ClogRateMetric a owl:Class ;
    rdfs:label "Clog Rate Metric"@en ;
    rdfs:subClassOf spray:Metric .

spray:Controller a owl:Class ;
    rdfs:label "Controller"@en ;
    rdfs:subClassOf spray:Component .

spray:CurrentFunction a owl:Class ;
    rdfs:label "Current Function"@en,
        "目前資料功能"@zh ;
    rdfs:subClassOf spray:ServiceFunction .

spray:DashboardFunction a owl:Class ;
    rdfs:label "Dashboard Function"@en,
        "儀表板查詢功能"@zh ;
    rdfs:subClassOf spray:ServiceFunction .

spray:DiagnosisFunction a owl:Class ;
    rdfs:label "Diagnosis Function"@en,
        "診斷查詢功能"@zh ;
    rdfs:subClassOf spray:ServiceFunction .

spray:FileOntologyServiceMappingTableMd a spray:SourceFile,
        owl:NamedIndividual ;
    rdfs:label "ontology_service_mapping_table.md | Source: 04_Spraying_Service_Ontology/ontology_service_mapping_table.md"@en ;
    spray:describesArtifact spray:OntologyService01 ;
    spray:sourceFilePath "04_Spraying_Service_Ontology/ontology_service_mapping_table.md" .

spray:FileThresholdConfigNotesMd a spray:SourceFile,
        owl:NamedIndividual ;
    rdfs:label "threshold_config_notes.md | Source: 02_StatisticsService/05_threshold-config/threshold_config_notes.md"@en ;
    spray:describesArtifact spray:ThresholdConfigTemplate ;
    spray:sourceFilePath "02_統計Service/05_threshold-config/threshold_config_notes.md" .

spray:MaintainabilityMetric a owl:Class ;
    rdfs:label "Maintainability Metric"@en ;
    rdfs:subClassOf spray:Metric .

spray:MediumRisk a spray:RiskAssessment,
        owl:NamedIndividual ;
    rdfs:label "Medium Risk"@en ;
    spray:riskText "medium risk" .

spray:MetricTrendFunction a owl:Class ;
    rdfs:label "Metric Trend Function"@en,
        "指標趨勢查詢功能"@zh ;
    rdfs:subClassOf spray:ServiceFunction .

spray:Oven a owl:Class ;
    rdfs:label "Oven"@en,
        "烤箱"@zh ;
    rdfs:subClassOf spray:PhysicalAsset .

spray:PastFunction a owl:Class ;
    rdfs:label "Past Function"@en,
        "過去資料功能"@zh ;
    rdfs:subClassOf spray:ServiceFunction .

spray:PredictionFunction a owl:Class ;
    rdfs:label "Prediction Function"@en,
        "預測功能"@zh ;
    rdfs:subClassOf spray:FutureFunction .

spray:PrimerProcessStep01 a spray:SprayProcessStep,
        owl:NamedIndividual ;
    rdfs:label "Primer process step"@en,
        "底漆製程步驟"@zh ;
    spray:precedesProcessStep spray:TopcoatProcessStep01 .

spray:RuleService01 a spray:RuleService,
        owl:NamedIndividual ;
    rdfs:label "RuleService_01"@en ;
    spray:serviceName "rule_service" ;
    spray:usesThresholdConfig spray:ThresholdConfigTemplate .

spray:RuntimeWindowFunction a owl:Class ;
    rdfs:label "Runtime Window Function"@en,
        "運行視窗查詢功能"@zh ;
    rdfs:subClassOf spray:ServiceFunction .

spray:Sensor a owl:Class ;
    rdfs:label "Sensor"@en ;
    rdfs:subClassOf spray:Component .

spray:SprayLine01 a spray:SprayLine,
        owl:NamedIndividual ;
    rdfs:label "SprayLine_01"@en ;
    spray:hasStation spray:LineM1,
        spray:LineM2,
        spray:LineM3 .

spray:SprayWidth a owl:Class ;
    rdfs:label "Spray Width"@en,
        "噴幅"@zh ;
    rdfs:comment "UI_v3 added SprayWidth and SprayWidthImage as new dashboard elements."@en,
        "UI_v3 新增 SprayWidth / 噴幅與 SprayWidthImage / 噴幅影像。"@zh ;
    rdfs:subClassOf spray:Component .

spray:SprayWidthImage a owl:Class ;
    rdfs:label "Spray Width Image"@en,
        "噴幅影像"@zh ;
    rdfs:subClassOf spray:InterfaceAsset .

spray:Standby a spray:StationState,
        owl:NamedIndividual ;
    rdfs:label "Standby"@en ;
    spray:stateText "Standby" .

spray:Stop a spray:StationState,
        owl:NamedIndividual ;
    rdfs:label "Stop"@en ;
    spray:stateText "Stop" .

spray:TenBatchWindow a owl:Class ;
    rdfs:label "Ten Batch Window"@en ;
    rdfs:subClassOf spray:BatchWindow,
        spray:HistoricalWindow .

spray:TimeSeriesViewerOutput a owl:Class ;
    rdfs:label "Time Series Viewer Output"@en ;
    rdfs:subClassOf spray:RuntimeData .

spray:TwoHourWindow a owl:Class ;
    rdfs:label "Two Hour Window"@en ;
    rdfs:subClassOf spray:HistoricalWindow,
        spray:TimeWindow .

spray:affectsDownstreamStep a owl:ObjectProperty ;
    rdfs:label "affects downstream step"@en,
        "影響下游製程步驟"@zh ;
    rdfs:domain spray:Entity ;
    rdfs:range spray:ProcessStep .

spray:affectsFinalResult a owl:ObjectProperty ;
    rdfs:label "affects final result"@en,
        "影響最終結果"@zh ;
    rdfs:domain spray:Entity ;
    rdfs:range spray:RuntimeData .

spray:affectsOutputField a owl:ObjectProperty ;
    rdfs:label "affects output field"@en ;
    rdfs:comment "Links a threshold configuration to JSON output fields that may be affected by threshold-based judgment."@en ;
    rdfs:domain spray:ThresholdConfig ;
    rdfs:range spray:JSONField .

spray:aggregatesCurrentSnapshot a owl:ObjectProperty ;
    rdfs:label "aggregates current snapshot"@en ;
    rdfs:domain spray:StatisticsService ;
    rdfs:range spray:CurrentStationSnapshot .

spray:aggregatesPastSnapshot a owl:ObjectProperty ;
    rdfs:label "aggregates past snapshot"@en ;
    rdfs:domain spray:StatisticsService ;
    rdfs:range spray:PastStationSnapshot .

spray:alignedWithOntology a owl:ObjectProperty ;
    rdfs:label "aligned with ontology"@en ;
    rdfs:domain spray:DataContractArtifact ;
    rdfs:range spray:OntologyService .

spray:convertedToRuntimeTTL a owl:ObjectProperty ;
    rdfs:label "converted to runtime TTL"@en ;
    rdfs:domain spray:RuntimeData ;
    rdfs:range spray:RuntimeTTLArtifact .

spray:definedInSourceFile a owl:ObjectProperty ;
    rdfs:label "defined in source file"@en ;
    rdfs:comment "Links an ontology artifact or concept back to the project source file where it is defined or documented."@en ;
    rdfs:domain spray:Entity ;
    rdfs:range spray:SourceFile .

spray:describesArtifact a owl:ObjectProperty ;
    rdfs:label "describes artifact"@en ;
    rdfs:comment "Links a project source file to the ontology artifact or concept it describes."@en ;
    rdfs:domain spray:SourceFile ;
    rdfs:range spray:Entity .

spray:describesStation a owl:ObjectProperty ;
    rdfs:label "describes station"@en ;
    rdfs:domain spray:RuntimeData ;
    rdfs:range spray:Station .

spray:displayLabel a owl:DatatypeProperty ;
    rdfs:label "display label"@en ;
    rdfs:domain spray:Entity ;
    rdfs:range xsd:string .

spray:displayedBy a owl:ObjectProperty ;
    rdfs:label "displayed by"@en ;
    rdfs:domain spray:DashboardSnapshot ;
    rdfs:range spray:InterfaceAsset .

spray:generatedAt a owl:DatatypeProperty ;
    rdfs:label "generated at"@en ;
    rdfs:domain spray:RuntimeData ;
    rdfs:range xsd:string .

spray:generatedBy a owl:ObjectProperty ;
    rdfs:label "generated by"@en ;
    rdfs:domain spray:RuntimeData ;
    rdfs:range spray:Service .

spray:hasAppliesToScope a owl:ObjectProperty ;
    rdfs:label "has applies-to scope"@en ;
    rdfs:domain spray:ThresholdConfig ;
    rdfs:range spray:AppliesToScope .

