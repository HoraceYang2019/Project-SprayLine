spray:hasUpstreamCause a owl:ObjectProperty ;
    rdfs:label "has upstream cause"@en,
        "具有上游原因"@zh ;
    rdfs:comment "This points from a downstream result to an upstream cause for explanation. It does not mean the downstream result affects the upstream component."@en,
        "此關係用於從下游結果回指上游原因，僅作解釋用途，不代表下游結果會反向影響上游元件。"@zh ;
    rdfs:domain spray:RuntimeData ;
    rdfs:range spray:Entity .

spray:hasUpstreamService a owl:ObjectProperty ;
    rdfs:label "has upstream service"@en ;
    rdfs:domain spray:Service ;
    rdfs:range spray:Service .

