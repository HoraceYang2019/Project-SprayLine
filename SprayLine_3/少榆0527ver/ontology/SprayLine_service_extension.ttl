#################################################################
# 17. Service data-flow assertions
#################################################################

:PastService_01
 :produces :PastSnapshot_M1_W001, :PastSnapshot_M2_W001, :PastSnapshot_M3_W001 ;
 :hasOutput :PastSnapshot_M1_W001, :PastSnapshot_M2_W001, :PastSnapshot_M3_W001 .

:CurrentService_01
 :produces :CurrentSnapshot_M1_W002, :CurrentSnapshot_M2_W002, :CurrentSnapshot_M3_W002 ;
 :hasOutput :CurrentSnapshot_M1_W002, :CurrentSnapshot_M2_W002, :CurrentSnapshot_M3_W002 .

:FutureService_01
 :usesPastSnapshot :PastSnapshot_M1_W001, :PastSnapshot_M2_W001, :PastSnapshot_M3_W001 ;
 :usesCurrentSnapshot :CurrentSnapshot_M1_W002, :CurrentSnapshot_M2_W002, :CurrentSnapshot_M3_W002 ;
 :produces :FuturePrediction_M1_W003, :FuturePrediction_M2_W003, :FuturePrediction_M3_W003 ;
 :hasOutput :FuturePrediction_M1_W003, :FuturePrediction_M2_W003, :FuturePrediction_M3_W003 .

:StatisticsService
 :aggregatesPastSnapshot :PastSnapshot_M1_W001, :PastSnapshot_M2_W001, :PastSnapshot_M3_W001 ;
 :aggregatesCurrentSnapshot :CurrentSnapshot_M1_W002, :CurrentSnapshot_M2_W002, :CurrentSnapshot_M3_W002 ;
 :usesFuturePrediction :FuturePrediction_M1_W003, :FuturePrediction_M2_W003, :FuturePrediction_M3_W003 ;
 :produces :StatisticsSummary_M1_W004, :StatisticsSummary_M2_W004, :StatisticsSummary_M3_W004, :LineSummary_001, :TrendSeries_001, :DashboardSnapshot_001 ;
 :hasOutput :DashboardSnapshot_001 .

