#################################################################
# 21. Threshold config individuals and source-aware annotations
#################################################################

:ThresholdConfigTemplate
    rdfs:comment "Source file: 02_統計Service/05_threshold-config/threshold_config.template.json. This node represents the threshold configuration template only; actual threshold values, warning rules, alarm rules, and risk formulas are not finalized."@en ;
    :sourceFilePath "02_統計Service/05_threshold-config/threshold_config.template.json" ;
    :definedInSourceFile :FileThresholdConfigTemplateJson ;
    :hasThresholdRule :WarningRuleTemplate, :AlarmRuleTemplate ;
    :hasThresholdSourceType :ExpertKnowledgeSource, :SystemConfigurationSource, :RuleServiceConfigSource, :FutureRiskModelSource ;
    :hasAppliesToScope :LineScope, :StationScope, :ComponentScope, :MetricScope, :ProcessParameterScope, :FuturePredictionScope ;
    :affectsOutputField :FieldState, :FieldMetrics, :FieldProcessParameters .

:WarningRuleTemplate rdf:type owl:NamedIndividual, :WarningRule ;
    rdfs:label "warning_rule template"@en ;
    rdfs:comment "Source file: 02_統計Service/05_threshold-config/threshold_config.template.json. Placeholder warning-level rule expression; not a finalized formula."@en ;
    :sourceFilePath "02_統計Service/05_threshold-config/threshold_config.template.json" .

:AlarmRuleTemplate rdf:type owl:NamedIndividual, :AlarmRule ;
    rdfs:label "alarm_rule template"@en ;
    rdfs:comment "Source file: 02_統計Service/05_threshold-config/threshold_config.template.json. Placeholder alarm-level rule expression; not a finalized formula."@en ;
    :sourceFilePath "02_統計Service/05_threshold-config/threshold_config.template.json" .

:ExpertKnowledgeSource rdf:type owl:NamedIndividual, :ThresholdSourceType ;
    rdfs:label "expert knowledge"@en ;
    rdfs:comment "Threshold values may come from process experts, engineers, or domain knowledge."@en .

:SystemConfigurationSource rdf:type owl:NamedIndividual, :ThresholdSourceType ;
    rdfs:label "system configuration"@en ;
    rdfs:comment "Threshold values may be managed as adjustable system configuration."@en .

:RuleServiceConfigSource rdf:type owl:NamedIndividual, :ThresholdSourceType ;
    rdfs:label "rule service config"@en ;
    rdfs:comment "Reserved for future extension because Rule Service is not yet an independent folder or executable service in the current project structure."@en .

:FutureRiskModelSource rdf:type owl:NamedIndividual, :ThresholdSourceType ;
    rdfs:label "future service risk model setting"@en ;
    rdfs:comment "Threshold values may be used by Future Service or risk model settings."@en .

:LineScope rdf:type owl:NamedIndividual, :AppliesToScope ;
    rdfs:label "line"@en .

:StationScope rdf:type owl:NamedIndividual, :AppliesToScope ;
    rdfs:label "station"@en .

:ComponentScope rdf:type owl:NamedIndividual, :AppliesToScope ;
    rdfs:label "component"@en .

:MetricScope rdf:type owl:NamedIndividual, :AppliesToScope ;
    rdfs:label "metric"@en .

:ProcessParameterScope rdf:type owl:NamedIndividual, :AppliesToScope ;
    rdfs:label "process parameter"@en .

:FuturePredictionScope rdf:type owl:NamedIndividual, :AppliesToScope ;
    rdfs:label "future prediction"@en .

