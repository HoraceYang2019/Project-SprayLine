    rdfs:label "has JSON field"@en ;
    rdfs:domain spray:FieldCatalog ;
    rdfs:range spray:JSONField .

spray:hasLineSummary a owl:ObjectProperty ;
    rdfs:label "has line summary"@en ;
    rdfs:domain spray:DashboardSnapshot ;
    rdfs:range spray:LineSummary .

spray:hasMetric a owl:ObjectProperty ;
    rdfs:label "has metric"@en ;
