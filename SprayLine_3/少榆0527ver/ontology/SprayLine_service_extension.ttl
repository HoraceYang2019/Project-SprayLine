spray:AlarmRule a owl:Class ;
    rdfs:label "Alarm Rule"@en ;
    rdfs:comment "A placeholder rule expression for alarm-level judgment."@en ;
    rdfs:subClassOf spray:ThresholdRule .

spray:AlarmRuleTemplate a spray:AlarmRule,
        owl:NamedIndividual ;
    rdfs:label "alarm_rule template"@en ;
    spray:sourceFilePath "02_統計Service/05_threshold-config/threshold_config.template.json" ;
    rdfs:comment "Source file: 02_統計Service/05_threshold-config/threshold_config.template.json. Placeholder alarm-level rule expression; not a finalized formula."@en .

