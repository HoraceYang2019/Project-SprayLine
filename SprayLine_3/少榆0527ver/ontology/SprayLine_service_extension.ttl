#################################################################
# 19. Source file mapping and threshold config extension
#################################################################

:SourceFile rdf:type owl:Class ;
    rdfs:subClassOf :DataContractArtifact ;
    rdfs:label "Source File"@en ;
    rdfs:comment "A project file that defines, documents, or supports an ontology artifact, schema, template, service contract, or configuration item. Source file paths are also written into rdfs:comment and sourceFilePath so that they can be inspected from Protégé / OntoGraf entity information panels."@en .

:describesArtifact rdf:type owl:ObjectProperty ;
    rdfs:domain :SourceFile ;
    rdfs:range :Entity ;
    rdfs:label "describes artifact"@en ;
    rdfs:comment "Links a project source file to the ontology artifact or concept it describes."@en .

:definedInSourceFile rdf:type owl:ObjectProperty ;
    rdfs:domain :Entity ;
    rdfs:range :SourceFile ;
    rdfs:label "defined in source file"@en ;
    rdfs:comment "Links an ontology artifact or concept back to the project source file where it is defined or documented."@en .

:sourceFilePath rdf:type owl:DatatypeProperty ;
    rdfs:domain :Entity ;
    rdfs:range xsd:string ;
    rdfs:label "source file path"@en ;
    rdfs:comment "A readable project-relative file path. This is provided to help Protégé users identify which source file a node corresponds to."@en .

:ThresholdRule rdf:type owl:Class ;
    rdfs:subClassOf :KnowledgeAsset ;
    rdfs:label "Threshold Rule"@en ;
    rdfs:comment "A rule expression associated with threshold configuration. This ontology defines the rule structure only; actual threshold values and formulas are not finalized."@en .

:WarningRule rdf:type owl:Class ;
    rdfs:subClassOf :ThresholdRule ;
    rdfs:label "Warning Rule"@en ;
    rdfs:comment "A placeholder rule expression for warning-level judgment."@en .

:AlarmRule rdf:type owl:Class ;
    rdfs:subClassOf :ThresholdRule ;
    rdfs:label "Alarm Rule"@en ;
    rdfs:comment "A placeholder rule expression for alarm-level judgment."@en .

:ThresholdSourceType rdf:type owl:Class ;
    rdfs:subClassOf :KnowledgeAsset ;
    rdfs:label "Threshold Source Type"@en ;
    rdfs:comment "The origin or management type of a threshold configuration, such as expert knowledge, system configuration, rule service config, or future risk model setting."@en .

:AppliesToScope rdf:type owl:Class ;
    rdfs:subClassOf :KnowledgeAsset ;
    rdfs:label "Applies To Scope"@en ;
    rdfs:comment "The scope where a threshold rule applies, such as line, station, component, metric, process parameter, or future prediction."@en .

:hasThresholdRule rdf:type owl:ObjectProperty ;
    rdfs:domain :ThresholdConfig ;
    rdfs:range :ThresholdRule ;
    rdfs:label "has threshold rule"@en .

:usesThresholdConfig rdf:type owl:ObjectProperty ;
    rdfs:domain :Service ;
    rdfs:range :ThresholdConfig ;
    rdfs:label "uses threshold config"@en ;
    rdfs:comment "Indicates that a service may refer to threshold configuration for rule-based or risk-related judgment. This does not mean the exact threshold values are finalized."@en .

:hasThresholdSourceType rdf:type owl:ObjectProperty ;
    rdfs:domain :ThresholdConfig ;
    rdfs:range :ThresholdSourceType ;
    rdfs:label "has threshold source type"@en .

:hasAppliesToScope rdf:type owl:ObjectProperty ;
    rdfs:domain :ThresholdConfig ;
    rdfs:range :AppliesToScope ;
    rdfs:label "has applies-to scope"@en .

:affectsOutputField rdf:type owl:ObjectProperty ;
    rdfs:domain :ThresholdConfig ;
    rdfs:range :JSONField ;
    rdfs:label "affects output field"@en ;
    rdfs:comment "Links a threshold configuration to JSON output fields that may be affected by threshold-based judgment."@en .

