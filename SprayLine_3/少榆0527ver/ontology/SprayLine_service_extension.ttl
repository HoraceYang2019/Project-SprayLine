        spray:StatisticsSummaryLineM3W004,
        spray:TrendSeries001 ;
    spray:serviceName "statistics_service" ;
    spray:usesFuturePrediction spray:FuturePredictionLineM1W003,
        spray:FuturePredictionLineM2W003,
        spray:FuturePredictionLineM3W003 ;
    spray:usesThresholdConfig spray:ThresholdConfigTemplate ;
    rdfs:comment "Aggregates past, current, and future data into dashboard and time-series outputs."@en ;
    rdfs:subClassOf spray:Service .

spray:SourceFile a owl:Class ;
    rdfs:label "Source File"@en ;
    rdfs:comment "A project file that defines, documents, or supports an ontology artifact, schema, template, service contract, or configuration item. Source file paths are also written into rdfs:comment and sourceFilePath so that they can be inspected from Protégé / OntoGraf entity information panels."@en ;
    rdfs:subClassOf spray:DataContractArtifact .

spray:Service a owl:Class ;
    rdfs:label "Service"@en ;
    rdfs:subClassOf spray:CyberAsset .

spray:RuntimeData a owl:Class ;
    rdfs:label "Runtime Data"@en ;
    rdfs:subClassOf spray:CyberAsset .

