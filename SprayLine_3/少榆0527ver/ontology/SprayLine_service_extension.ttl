# 20. Source file individuals
#################################################################

:File_field_catalog_csv rdf:type owl:NamedIndividual, :SourceFile ;
    rdfs:label "field_catalog.csv | Source: 02_StatisticsService/02_field-catalog/field_catalog.csv"@en ;
    :sourceFilePath "02_統計Service/02_field-catalog/field_catalog.csv" ;
    :describesArtifact :FieldCatalog .

