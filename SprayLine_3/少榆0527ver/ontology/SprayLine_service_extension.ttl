#################################################################
# Service extension additions: Function, UI_v3, process flow
#################################################################

:Function rdf:type owl:Class ;
    rdfs:subClassOf :CyberAsset ;
    rdfs:label "Function"@en ;
    rdfs:label "功能"@zh ;
    rdfs:comment "A service operation, API function, or database query function used by UI, services, or database access."@en ;
    rdfs:comment "由 UI、Services 或 Database 存取使用的服務操作、API function 或資料庫查詢功能。"@zh .

:ServiceFunction rdf:type owl:Class ;
    rdfs:subClassOf :Function ;
    rdfs:label "Service Function"@en ;
    rdfs:label "服務功能"@zh .

:PastFunction rdf:type owl:Class ;
    rdfs:subClassOf :ServiceFunction ;
    rdfs:label "Past Function"@en ;
    rdfs:label "過去資料功能"@zh .

:CurrentFunction rdf:type owl:Class ;
    rdfs:subClassOf :ServiceFunction ;
    rdfs:label "Current Function"@en ;
    rdfs:label "目前資料功能"@zh .

:FutureFunction rdf:type owl:Class ;
    rdfs:subClassOf :ServiceFunction ;
    rdfs:label "Future Function"@en ;
    rdfs:label "未來預測功能"@zh .

:RuntimeWindowFunction rdf:type owl:Class ;
    rdfs:subClassOf :ServiceFunction ;
    rdfs:label "Runtime Window Function"@en ;
    rdfs:label "運行視窗查詢功能"@zh .

:MetricTrendFunction rdf:type owl:Class ;
    rdfs:subClassOf :ServiceFunction ;
    rdfs:label "Metric Trend Function"@en ;
    rdfs:label "指標趨勢查詢功能"@zh .

:DiagnosisFunction rdf:type owl:Class ;
    rdfs:subClassOf :ServiceFunction ;
    rdfs:label "Diagnosis Function"@en ;
    rdfs:label "診斷查詢功能"@zh .

:DashboardFunction rdf:type owl:Class ;
    rdfs:subClassOf :ServiceFunction ;
    rdfs:label "Dashboard Function"@en ;
    rdfs:label "儀表板查詢功能"@zh .

:PredictionFunction rdf:type owl:Class ;
    rdfs:subClassOf :FutureFunction ;
    rdfs:label "Prediction Function"@en ;
    rdfs:label "預測功能"@zh .

:FunctionInputParameter rdf:type owl:Class ;
    rdfs:subClassOf :DataContractArtifact ;
    rdfs:label "Function Input Parameter"@en ;
    rdfs:label "功能輸入參數"@zh .

:FunctionOutputParameter rdf:type owl:Class ;
    rdfs:subClassOf :DataContractArtifact ;
    rdfs:label "Function Output Parameter"@en ;
    rdfs:label "功能輸出參數"@zh .

:hasInputParameter rdf:type owl:ObjectProperty ;
    rdfs:domain :Function ;
    rdfs:range :FunctionInputParameter ;
    rdfs:label "has input parameter"@en ;
    rdfs:label "具有輸入參數"@zh .

:hasOutputParameter rdf:type owl:ObjectProperty ;
    rdfs:domain :Function ;
    rdfs:range :FunctionOutputParameter ;
    rdfs:label "has output parameter"@en ;
    rdfs:label "具有輸出參數"@zh .

:queriesDatabase rdf:type owl:ObjectProperty ;
    rdfs:domain :Function ;
    rdfs:range :Database ;
    rdfs:label "queries database"@en ;
    rdfs:label "查詢資料庫"@zh .

:usesFunction rdf:type owl:ObjectProperty ;
    rdfs:domain :Service ;
    rdfs:range :Function ;
    rdfs:label "uses function"@en ;
    rdfs:label "使用功能"@zh .

:lineId rdf:type owl:DatatypeProperty ;
    rdfs:domain :Entity ;
    rdfs:range xsd:string ;
    rdfs:label "line id"@en ;
    rdfs:label "產線編號"@zh ;
    rdfs:comment "The database-facing identifier uses line_id. Station labels may still describe process positions such as primer, topcoat, and gold paint."@en ;
    rdfs:comment "與 Database function 對接的識別欄位使用 line_id；底漆、面漆、金漆等 station 概念仍可作為製程位置或 UI 顯示標籤。"@zh .

:AirCompressor rdf:type owl:Class ;
    rdfs:subClassOf :Component ;
    rdfs:label "Air Compressor"@en ;
    rdfs:label "空壓機"@zh ;
    rdfs:comment "UI_v3 replaces Pump with AirCompressor."@en ;
    rdfs:comment "UI_v3 中 Pump 改為 AirCompressor / 空壓機。"@zh .

:SprayWidth rdf:type owl:Class ;
    rdfs:subClassOf :Component ;
    rdfs:label "Spray Width"@en ;
    rdfs:label "噴幅"@zh ;
    rdfs:comment "UI_v3 added SprayWidth and SprayWidthImage as new dashboard elements."@en ;
    rdfs:comment "UI_v3 新增 SprayWidth / 噴幅與 SprayWidthImage / 噴幅影像。"@zh .

:SprayWidthImage rdf:type owl:Class ;
    rdfs:subClassOf :InterfaceAsset ;
    rdfs:label "Spray Width Image"@en ;
    rdfs:label "噴幅影像"@zh .

:ProcessStep rdf:type owl:Class ;
    rdfs:subClassOf :RuntimeData ;
    rdfs:label "Process Step"@en ;
    rdfs:label "製程步驟"@zh .

:SprayProcessStep rdf:type owl:Class ;
    rdfs:subClassOf :ProcessStep ;
    rdfs:label "Spray Process Step"@en ;
    rdfs:label "噴塗製程步驟"@zh .

:BakingStep rdf:type owl:Class ;
    rdfs:subClassOf :ProcessStep ;
    rdfs:label "Baking Step"@en ;
    rdfs:label "烘烤步驟"@zh .

:Oven rdf:type owl:Class ;
    rdfs:subClassOf :PhysicalAsset ;
    rdfs:label "Oven"@en ;
    rdfs:label "烤箱"@zh .

:BakingResult rdf:type owl:Class ;
    rdfs:subClassOf :RuntimeData ;
    rdfs:label "Baking Result"@en ;
    rdfs:label "烘烤結果"@zh .

:FaultPropagation rdf:type owl:Class ;
    rdfs:subClassOf :KnowledgeAsset ;
    rdfs:label "Fault Propagation"@en ;
    rdfs:label "異常傳遞關係"@zh .

:precedesProcessStep rdf:type owl:ObjectProperty ;
    rdfs:domain :ProcessStep ;
    rdfs:range :ProcessStep ;
    rdfs:label "precedes process step"@en ;
    rdfs:label "先於製程步驟"@zh .

:affectsDownstreamStep rdf:type owl:ObjectProperty ;
    rdfs:domain :Entity ;
    rdfs:range :ProcessStep ;
    rdfs:label "affects downstream step"@en ;
    rdfs:label "影響下游製程步驟"@zh .

:affectsFinalResult rdf:type owl:ObjectProperty ;
    rdfs:domain :Entity ;
    rdfs:range :RuntimeData ;
    rdfs:label "affects final result"@en ;
    rdfs:label "影響最終結果"@zh .

:hasUpstreamCause rdf:type owl:ObjectProperty ;
    rdfs:domain :RuntimeData ;
    rdfs:range :Entity ;
    rdfs:label "has upstream cause"@en ;
    rdfs:label "具有上游原因"@zh ;
    rdfs:comment "This points from a downstream result to an upstream cause for explanation. It does not mean the downstream result affects the upstream component."@en ;
    rdfs:comment "此關係用於從下游結果回指上游原因，僅作解釋用途，不代表下游結果會反向影響上游元件。"@zh .

:producesBakingResult rdf:type owl:ObjectProperty ;
    rdfs:domain :BakingStep ;
    rdfs:range :BakingResult ;
    rdfs:label "produces baking result"@en ;
    rdfs:label "產生烘烤結果"@zh .

:PrimerProcessStep_01 rdf:type owl:NamedIndividual, :SprayProcessStep ;
    rdfs:label "Primer process step"@en ;
    rdfs:label "底漆製程步驟"@zh .

:TopcoatProcessStep_01 rdf:type owl:NamedIndividual, :SprayProcessStep ;
    rdfs:label "Topcoat process step"@en ;
    rdfs:label "面漆製程步驟"@zh .

:GoldPaintProcessStep_01 rdf:type owl:NamedIndividual, :SprayProcessStep ;
    rdfs:label "Gold paint process step"@en ;
    rdfs:label "金漆製程步驟"@zh .

:BakingStep_01 rdf:type owl:NamedIndividual, :BakingStep ;
    rdfs:label "Baking step"@en ;
    rdfs:label "烘烤步驟"@zh .

:BakingResult_TEMPLATE rdf:type owl:NamedIndividual, :BakingResult ;
    rdfs:label "Baking result template"@en ;
    rdfs:label "烘烤結果模板"@zh .

:PrimerProcessStep_01 :precedesProcessStep :TopcoatProcessStep_01 .
:TopcoatProcessStep_01 :precedesProcessStep :GoldPaintProcessStep_01 .
:GoldPaintProcessStep_01 :precedesProcessStep :BakingStep_01 .
:BakingStep_01 :producesBakingResult :BakingResult_TEMPLATE .

:FilterMeshFault_TEMPLATE rdf:type owl:NamedIndividual, :FaultPropagation ;
    rdfs:label "Filter mesh fault template"@en ;
    rdfs:label "濾網異常模板"@zh ;
    :affectsDownstreamStep :BakingStep_01 ;
    :affectsFinalResult :BakingResult_TEMPLATE .

:BakingResult_TEMPLATE :hasUpstreamCause :FilterMeshFault_TEMPLATE .
