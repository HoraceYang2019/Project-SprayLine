#################################################################
# 17. Service data-flow assertions
#################################################################

:PastService01
 :produces :PastSnapshotLineM1W001, :PastSnapshotLineM2W001, :PastSnapshotLineM3W001 ;
 :hasOutput :PastSnapshotLineM1W001, :PastSnapshotLineM2W001, :PastSnapshotLineM3W001 .

:CurrentService01
 :produces :CurrentSnapshotLineM1W002, :CurrentSnapshotLineM2W002, :CurrentSnapshotLineM3W002 ;
 :hasOutput :CurrentSnapshotLineM1W002, :CurrentSnapshotLineM2W002, :CurrentSnapshotLineM3W002 .

:FutureService01
 :usesPastSnapshot :PastSnapshotLineM1W001, :PastSnapshotLineM2W001, :PastSnapshotLineM3W001 ;
 :usesCurrentSnapshot :CurrentSnapshotLineM1W002, :CurrentSnapshotLineM2W002, :CurrentSnapshotLineM3W002 ;
 :produces :FuturePredictionLineM1W003, :FuturePredictionLineM2W003, :FuturePredictionLineM3W003 ;
 :hasOutput :FuturePredictionLineM1W003, :FuturePredictionLineM2W003, :FuturePredictionLineM3W003 .

:StatisticsService
 :aggregatesPastSnapshot :PastSnapshotLineM1W001, :PastSnapshotLineM2W001, :PastSnapshotLineM3W001 ;
 :aggregatesCurrentSnapshot :CurrentSnapshotLineM1W002, :CurrentSnapshotLineM2W002, :CurrentSnapshotLineM3W002 ;
 :usesFuturePrediction :FuturePredictionLineM1W003, :FuturePredictionLineM2W003, :FuturePredictionLineM3W003 ;
 :produces :StatisticsSummaryLineM1W004, :StatisticsSummaryLineM2W004, :StatisticsSummaryLineM3W004, :LineSummary001, :TrendSeries001, :DashboardSnapshot001 ;
 :hasOutput :DashboardSnapshot001 .

