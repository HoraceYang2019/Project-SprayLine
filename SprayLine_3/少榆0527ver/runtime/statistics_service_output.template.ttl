# Runtime TTL template
# This file is a parseable template for converting Statistics Service / UI dashboard output
# into runtime TTL individuals. It is NOT a real runtime observation and contains no fake data.

@prefix : <http://nkust.edu.tw/mislab/spraying/ontology#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

:DashboardSnapshot_TEMPLATE
    rdf:type :DashboardSnapshot ;
    rdfs:label "DashboardSnapshot_TEMPLATE"@en ;
    rdfs:label "儀表板快照_TEMPLATE"@zh ;
    rdfs:comment "Runtime placeholder. Replace TEMPLATE with real identifiers when generated from service output or database query result."@en ;
    rdfs:comment "Runtime 佔位節點。未來由 service output 或 database query result 產生時，需用真實識別資訊取代 TEMPLATE。"@zh .

:StatisticsWindow_TEMPLATE
    rdf:type :StatisticsWindow ;
    rdfs:label "StatisticsWindow_TEMPLATE"@en ;
    rdfs:label "統計視窗_TEMPLATE"@zh .

:LineSnapshot_TEMPLATE
    rdf:type :StationSnapshot ;
    rdfs:label "LineSnapshot_TEMPLATE"@en ;
    rdfs:label "產線快照_TEMPLATE"@zh ;
    rdfs:comment "The identifier field is line_id. Station names such as PrimerStation, TopcoatStation, and GoldPaintStation may still be used as UI/process labels."@en ;
    rdfs:comment "識別欄位使用 line_id；底漆站、面漆站、金漆站等 station 名稱仍可作為 UI 或製程顯示概念。"@zh .

:Metric_TEMPLATE
    rdf:type :Metric ;
    rdfs:label "Metric_TEMPLATE"@en ;
    rdfs:label "指標_TEMPLATE"@zh .

:RiskAssessment_TEMPLATE
    rdf:type :RiskAssessment ;
    rdfs:label "RiskAssessment_TEMPLATE"@en ;
    rdfs:label "風險評估_TEMPLATE"@zh .

:DashboardSnapshot_TEMPLATE
    :hasWindow :StatisticsWindow_TEMPLATE ;
    :hasStationSummary :LineSnapshot_TEMPLATE .

:LineSnapshot_TEMPLATE
    :hasMetric :Metric_TEMPLATE ;
    :hasRiskAssessment :RiskAssessment_TEMPLATE .
