{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sensor feature window",
  "type": "object",
  "properties": {
    "station": {
      "type": "string"
    },
    "sensor_name": {
      "type": "string"
    },
    "source_table": {
      "type": "string",
      "enum": [
        "sensor_1min",
        "sensor_3min"
      ]
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "window_start": {
            "type": "string",
            "format": "date-time"
          },
          "avg": {
            "type": [
              "number",
              "null"
            ]
          },
          "stddev": {
            "type": [
              "number",
              "null"
            ]
          },
          "count": {
            "type": "integer"
          }
        },
        "required": [
          "window_start",
          "count"
        ]
      }
    }
  },
  "required": [
    "station",
    "sensor_name",
    "source_table",
    "rows"
  ],
  "additionalProperties": false
}
