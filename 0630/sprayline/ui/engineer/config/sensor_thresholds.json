{
  "version": "step2_formal_db_metrics",
  "source": "Formal DB route only: thresholds aligned with spray0621verC available fields and derived service metrics.",
  "rules": {
    "filter_diff_pressure_bar": {
      "source_table": "sensor_1min",
      "unit": "bar",
      "normal": {
        "min": 0.1,
        "max": 0.5
      },
      "warning": [
        {
          "min_exclusive": 0.5,
          "max": 0.7
        }
      ],
      "fault": [
        {
          "min_exclusive": 0.7
        }
      ]
    },
    "servo_torque_load_pct": {
      "source_table": "sensor_1min",
      "unit": "%",
      "normal": {
        "min": 40.0,
        "max": 60.0
      },
      "warning": [
        {
          "min_exclusive": 60.0,
          "max": 75.0
        }
      ],
      "fault": [
        {
          "min_exclusive": 75.0
        }
      ]
    },
    "air_pressure_bar": {
      "source_table": "sensor_1min",
      "unit": "bar",
      "normal": {
        "min": 2.7,
        "max": 3.8
      },
      "warning": [
        {
          "min": 2.5,
          "max_exclusive": 2.7
        },
        {
          "min_exclusive": 3.8,
          "max": 4.0
        }
      ],
      "fault": [
        {
          "max_exclusive": 2.5
        },
        {
          "min_exclusive": 4.0
        }
      ],
      "note": "0620ver_1: generated normal air pressure is around Station_1=3.5, Station_2=3.2, Station_3=3.0; keep global safe band instead of switching rule engine to DB thresholds."
    },
    "temperature_c": {
      "source_table": "sensor_3min",
      "unit": "degC",
      "normal": {
        "min": 20.0,
        "max": 30.0
      },
      "warning": [
        {
          "min": 15.0,
          "max_exclusive": 20.0
        },
        {
          "min_exclusive": 30.0,
          "max": 35.0
        }
      ],
      "fault": [
        {
          "max_exclusive": 15.0
        },
        {
          "min_exclusive": 35.0
        }
      ]
    },
    "humidity_rh": {
      "source_table": "sensor_3min",
      "unit": "%RH",
      "normal": {
        "min": 45.0,
        "max": 65.0
      },
      "warning": [
        {
          "min": 35.0,
          "max_exclusive": 45.0
        },
        {
          "min_exclusive": 65.0,
          "max": 75.0
        }
      ],
      "fault": [
        {
          "max_exclusive": 35.0
        },
        {
          "min_exclusive": 75.0
        }
      ]
    },
    "paint_flow_ml_min": {
      "source_table": "sensor_1min",
      "unit": "ml/min",
      "normal": {
        "min": 105.0,
        "max": 125.0
      },
      "warning": [
        {
          "min": 95.0,
          "max_exclusive": 105.0
        }
      ],
      "fault": [
        {
          "max_exclusive": 95.0
        },
        {
          "min_exclusive": 125.0
        }
      ]
    },
    "spray_width_mm": {
      "source_table": "sensor_1min",
      "unit": "mm",
      "normal": {
        "min": 70.0,
        "max": 130.0
      },
      "warning": [
        {
          "min": 60.0,
          "max_exclusive": 70.0
        },
        {
          "min_exclusive": 130.0,
          "max": 140.0
        }
      ],
      "fault": [
        {
          "max_exclusive": 60.0
        },
        {
          "min_exclusive": 140.0
        }
      ],
      "note": "0620ver_1: generated station baselines are Station_1≈120, Station_2≈100, Station_3≈82. This global safe band avoids false alarms until station-specific rules are introduced."
    },
    "path_error_mm": {
      "source_table": "sensor_1min",
      "unit": "mm",
      "normal": {
        "min": 0.0,
        "max": 0.1
      },
      "warning": [
        {
          "min_exclusive": 0.1,
          "max": 0.15
        }
      ],
      "fault": [
        {
          "min_exclusive": 0.15
        }
      ]
    },
    "quality_score_pct": {
      "source_table": "derived_service_metric",
      "unit": "%",
      "normal": {
        "min": 90.0,
        "max": 100.0
      },
      "warning": [
        {
          "min": 70.0,
          "max_exclusive": 90.0
        }
      ],
      "fault": [
        {
          "max_exclusive": 70.0
        }
      ],
      "note": "Formal DB step2: quality_score_pct is derived from flow, pressure, spray width and path error; it is not actual inspection yield."
    },
    "estimated_defect_rate_pct": {
      "source_table": "derived_service_metric",
      "unit": "%",
      "normal": {
        "min": 0.0,
        "max": 10.0
      },
      "warning": [
        {
          "min_exclusive": 10.0,
          "max": 30.0
        }
      ],
      "fault": [
        {
          "min_exclusive": 30.0
        }
      ],
      "note": "Formal DB step2: Qc is estimated defect rate from abnormal process-condition samples."
    },
    "qc_pct": {
      "source_table": "derived_service_metric",
      "unit": "%",
      "normal": {
        "min": 0.0,
        "max": 10.0
      },
      "warning": [
        {
          "min_exclusive": 10.0,
          "max": 30.0
        }
      ],
      "fault": [
        {
          "min_exclusive": 30.0
        }
      ],
      "note": "Formal DB step2: Qc is estimated defect rate from abnormal process-condition samples."
    }
  }
}