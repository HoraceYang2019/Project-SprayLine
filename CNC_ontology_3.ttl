                           mill:hasCause mill:C10_InappropriateCuttingCondition_Roughness ,
                                         mill:C11_Adhesion_Roughness ,
                                         mill:C12_PoorRunoutAccuracy ,
                                         mill:C13_Chatter_Roughness ;
                           skos:altLabel "Excessive surface roughness"@en ;
                           skos:prefLabel "表面粗糙度大"@zh .


