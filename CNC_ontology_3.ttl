@prefix : <http://nkust.edu.tw/mislab/cnc/ontology/sth#STHExtendedOntology> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix mis: <http://nkust.edu.tw/mislab#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sth: <http://nkust.edu.tw/mislab/cnc/ontology/sth#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix mill: <http://nkust.edu.tw/mislab/cnc/ontology/milling-troubleshooting#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@base <http://nkust.edu.tw/mislab/cnc/ontology/sth#STHExtendedOntology> .

<http://nkust.edu.tw/mislab/cnc/ontology/sth#STHExtendedOntology> rdf:type owl:Ontology ;
                                                                   owl:imports mill: ;
                                                                   rdfs:comment "Extended with TEC milling troubleshooting knowledge: failure modes, causes, and corrective countermeasures parsed from the uploaded milling troubleshooting chart."@en ,
                                                                                "Generated from uploaded image tec_milling_trouble_shooting_01_zh.png. Cell recommendations are based on detected black markers in the chart matrix and should be verified against the original manual before production use."@en ,
                                                                                "Ontology for CNC smart tool holder monitoring with NC files, NC blocks, sensing windows, multi-sensor alignment, diagnosis, prediction, and communication mapping."@en ;
                                                                   rdfs:label "CNC ontology extended with milling troubleshooting knowledge"@en ,
                                                                              "Extended Smart Tool Holder Ontology with NC File and Sensing Windows"@en ,
                                                                              "Milling troubleshooting ontology parsed from TEC chart"@en ,
                                                                              "铣削故障对策图谱本体"@zh ;
                                                                   owl:versionInfo "0.1.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/creator
dc:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/date
dc:date rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
skos:altLabel rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#prefLabel
skos:prefLabel rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#related
skos:related rdf:type owl:AnnotationProperty .


