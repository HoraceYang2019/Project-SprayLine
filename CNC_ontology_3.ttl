#################################################################
#    Classes
#################################################################

###  http://nkust.edu.tw/mislab#AICNCPipeline
mis:AICNCPipeline rdf:type owl:Class ;
                  rdfs:subClassOf sth:CyberAsset ;
                  rdfs:comment "A five-stage workflow that transforms sensing data into identified machining states, inferred causes/responses, evaluated force/tool/quality indicators, and adaptive tool or NC-code management actions."@en ;
                  rdfs:label "CNC closed-loop monitoring and adaption pipeline"@en .


###  http://nkust.edu.tw/mislab#AICNCStage
mis:AICNCStage rdf:type owl:Class ;
               rdfs:subClassOf sth:CyberAsset ;
               rdfs:label "CNC workflow stage"@en .


###  http://nkust.edu.tw/mislab#AdaptionAction
mis:AdaptionAction rdf:type owl:Class ;
                   rdfs:subClassOf mis:Prediction ;
                   rdfs:label "adaptation action"@en ,
                              "adaption action"@en .


###  http://nkust.edu.tw/mislab#AdaptionStage
mis:AdaptionStage rdf:type owl:Class ;
                  rdfs:subClassOf mis:AICNCStage ;
                  rdfs:comment "Stage that suggests tool management and process management actions, including tool change and updated NC codes."@en ;
                  rdfs:label "adaptation stage"@en ,
                             "adaption stage"@en .


