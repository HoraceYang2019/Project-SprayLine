###  http://nkust.edu.tw/mislab/cnc/ontology/milling-troubleshooting#ChipDisposal
mill:ChipDisposal rdf:type owl:NamedIndividual ,
                           mill:FailureCategory ;
                  skos:altLabel "Chip disposal / chip control"@en ;
                  skos:prefLabel "切屑处理"@zh .


###  http://nkust.edu.tw/mislab/cnc/ontology/milling-troubleshooting#ChipEntanglementClogging
mill:ChipEntanglementClogging rdf:type owl:NamedIndividual ,
                                       mill:FaultMode ;
                              mill:belongsToCategory mill:ChipDisposal ;
                              mill:hasCause mill:C25_Adhesion_ChipControl ,
                                            mill:C26_ChipTooThin ,
                                            mill:C27_CutterDiameterTooSmall ,
                                            mill:C28_PoorChipEvacuation ;
                              skos:altLabel "Chip entanglement / clogging"@en ;
                              skos:prefLabel "切屑缠绕堵塞"@zh .


###  http://nkust.edu.tw/mislab/cnc/ontology/milling-troubleshooting#CuttingConditions
mill:CuttingConditions rdf:type owl:NamedIndividual ,
                                mill:ResponseGroup ;
                       skos:altLabel "Cutting conditions"@en ;
                       skos:prefLabel "切削条件"@zh .


###  http://nkust.edu.tw/mislab/cnc/ontology/milling-troubleshooting#CuttingEdgeFracture
mill:CuttingEdgeFracture rdf:type owl:NamedIndividual ,
                                  mill:FaultMode ;
                         mill:belongsToCategory mill:ToolLifeDecrease ;
                         mill:hasCause mill:C04_InappropriateToolMaterial_Fracture ,
                                       mill:C05_InappropriateCuttingCondition_Fracture ,
                                       mill:C06_InsufficientEdgeStrength ,
                                       mill:C07_ThermalCrack ,
                                       mill:C08_BuiltUpEdge_Fracture ,
                                       mill:C09_InsufficientRigidity_Fracture ;
                         skos:altLabel "Cutting edge breakage / chipping"@en ;
                         skos:prefLabel "切削刃破损、崩刃"@zh .


###  http://nkust.edu.tw/mislab/cnc/ontology/milling-troubleshooting#EdgeBreakoutPeeling
mill:EdgeBreakoutPeeling rdf:type owl:NamedIndividual ,
                                  mill:FaultMode ;
                         mill:belongsToCategory mill:BurrAndChipping ;
                         mill:hasCause mill:C21_InappropriateCuttingCondition_Peeling ,
                                       mill:C22_PoorSharpness_Peeling ,
                                       mill:C23_SmallLeadAngle ,
                                       mill:C24_Chatter_Peeling ;
                         skos:altLabel "Breakout / peeling"@en ;
                         skos:prefLabel "发生崩碎、剥落"@zh .


###  http://nkust.edu.tw/mislab/cnc/ontology/milling-troubleshooting#FastToolWear
mill:FastToolWear rdf:type owl:NamedIndividual ,
                           mill:FaultMode ;
                  mill:belongsToCategory mill:ToolLifeDecrease ;
                  mill:hasCause mill:C01_InappropriateToolMaterial_Wear ,
                                mill:C02_InappropriateEdgeShape_Wear ,
                                mill:C03_InappropriateCuttingSpeed_Wear ;
                  skos:altLabel "Rapid insert wear"@en ;
                  skos:prefLabel "刀片磨损快"@zh .


###  http://nkust.edu.tw/mislab/cnc/ontology/milling-troubleshooting#FlatnessParallelismDeterioration
mill:FlatnessParallelismDeterioration rdf:type owl:NamedIndividual ,
                                               mill:FaultMode ;
                                      mill:belongsToCategory mill:SurfaceAccuracyDeterioration ;
                                      mill:hasCause mill:C14_WorkpieceBending ,
                                                    mill:C15_ToolPositionOffset ,
                                                    mill:C16_LargeBackForce ;
                                      skos:altLabel "Flatness / parallelism deterioration"@en ;
                                      skos:prefLabel "平面度、平行度恶化"@zh .


###  http://nkust.edu.tw/mislab/cnc/ontology/milling-troubleshooting#LargeSurfaceRoughness
mill:LargeSurfaceRoughness rdf:type owl:NamedIndividual ,
