                              mill:FailureCategory ;
                     skos:altLabel "Burrs and chipping"@en ;
                     skos:prefLabel "毛刺及崩碎"@zh .


###  http://nkust.edu.tw/mislab/cnc/ontology/milling-troubleshooting#BurrGeneration
mill:BurrGeneration rdf:type owl:NamedIndividual ,
                             mill:FaultMode ;
                    mill:belongsToCategory mill:BurrAndChipping ;
                    mill:hasCause mill:C17_ChipTooThick ,
                                  mill:C18_CutterDiameterTooLarge ,
                                  mill:C19_PoorSharpness_Burr ,
                                  mill:C20_LargeLeadAngle ;
                    skos:altLabel "Burr generation"@en ;
                    skos:prefLabel "产生毛刺"@zh .


